  cloudSun:'<path d="M12 2v2M4.93 4.93l1.41 1.41M20 12h2M17.66 17.66l1.41 1.41M2 12h2M6.34 6.34L4.93 4.93M19.07 4.93l-1.41 1.41"/><circle cx="12" cy="12" r="4"/><path d="M17.5 21H9a5 5 0 010-10h.1A7 7 0 0121 13.5a4.5 4.5 0 01-3.5 7.5z"/>',
  gauge:'<circle cx="12" cy="12" r="10"/><path d="M12 8v4l2 2"/><path d="M16.24 7.76l-1.41 1.41"/>',
  barChart2:'<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
};

/* ========== AD SYSTEM ==========
   Ad Methodology:
   - Native ad cards that match app design, labeled "Sponsored" or "Partner Offer"
   - Premium upgrade banner in free tier
   - Partner financial product recommendations (savings, credit cards)
   - NO pop-ups, NO interstitials, NO video ads
   - User can control preferences in Settings > Ads & Monetization
   - All ads are static/demo — no real ad network integration
*/
function renderAd(type){
  if(type==='native' && !adPrefs.showNativeAds) return '';
  if(type==='premium' && !adPrefs.showPremiumBanner) return '';
  if(type==='partner' && !adPrefs.showPartnerOffers) return '';

  if(type==='native'){
    return '<div class="c ad-card" style="cursor:pointer"><div class="ad-label" title="Why this ad? NestWorth shows relevant financial offers. We never sell your data.">Sponsored</div><div class="r" style="gap:12px"><div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#0066ff,#00cc88);display:flex;align-items:center;justify-content:center;flex-shrink:0"><span style="font-size:16px;color:#fff;font-weight:800">A</span></div><div style="flex:1"><div style="font-weight:700;font-size:13px">Ally Savings — 4.25% APY</div><div class="sub">No minimums, no fees. FDIC insured.</div></div></div></div>';
  }
  if(type==='premium'){
    return '<div class="c" style="background:var(--goldG);border:none;cursor:pointer" onclick="os(\'NestWorth Premium\',sPremium())"><div class="r" style="gap:10px"><div style="flex:1"><div style="font-size:14px;font-weight:700;color:#fff">Upgrade to NestWorth Premium</div><div style="font-size:11px;color:rgba(255,255,255,0.8);margin-top:2px">Real-time sync, AI coaching, unlimited nests</div></div><div style="font-size:20px;color:#fff">&#x2192;</div></div></div>';
  }
  if(type==='partner'){
    return '<div class="c ad-card"><div class="ad-label" title="Why this ad? NestWorth shows relevant financial offers. We never sell your data.">Partner Offer</div><div style="font-weight:700;font-size:13px;margin-bottom:8px">Recommended for You</div>'+
    ['<div class="ci" style="margin-bottom:4px;cursor:pointer"><div class="r"><div style="flex:1"><div style="font-weight:600;font-size:11px">Wealthfront Cash — 5.0% APY</div><div class="sub">$0 fees, FDIC insured to $8M</div></div>'+bg('Top Pick','var(--pos)')+'</div></div>',
    '<div class="ci" style="margin-bottom:4px;cursor:pointer"><div class="r"><div style="flex:1"><div style="font-weight:600;font-size:11px">Chase Sapphire Preferred</div><div class="sub">60k bonus points, $95/yr</div></div>'+bg('Travel','var(--acc)')+'</div></div>'].join('')+'</div>';
  }
  return '';
}

function sPremium(){return '<div style="text-align:center;padding:10px"><div style="font-size:28px;font-weight:800;margin-bottom:4px">NestWorth Premium</div><div class="sub" style="margin-bottom:16px">Everything you need, nothing you don\'t</div></div>'+
['Real-time bank sync (vs daily)','AI-powered coaching & insights','Unlimited savings nests','Bill negotiation concierge','Priority support','Advanced tax reports','Custom budget categories','Partner spending alerts'].map(function(f){return '<div class="r" style="padding:5px 0;gap:8px">'+ic(icons.check,14,'var(--pos)',2.5)+'<span style="font-size:12px;font-weight:500">'+f+'</span></div>'}).join('')+
'<div style="text-align:center;margin-top:16px"><div style="font-size:32px;font-weight:900;color:var(--acc)">$9.99<span style="font-size:14px;font-weight:400;color:var(--t2)">/mo</span></div><div class="sub">or $99.99/year (save 17%)</div></div><button class="btn-gold btn-full" style="margin-top:14px;padding:14px;font-size:15px;border-radius:22px">Start Free Trial</button><div class="sub" style="margin-top:8px;text-align:center">7-day free trial, cancel anytime</div>'}


/* ========== HOME PAGE ========== */
function rHome(){
var wellnessScore=74,flex=1680;

if(isDesktop()){
/* ===== DESKTOP HOME DASHBOARD ===== */
var nwChartData=nwHistory.map(function(d){return {m:d.m,v:d.v}});
var spendDonutSegs=[
  {value:1500,color:'var(--t2)',label:'Housing'},
  {value:480,color:'var(--pos)',label:'Groceries'},
  {value:280,color:'var(--warn)',label:'Dining'},
  {value:235,color:'var(--neg)',label:'Shopping'},
  {value:120,color:'var(--info)',label:'Transport'},
  {value:85,color:'var(--acc)',label:'Entertainment'},
  {value:220,color:'var(--gold)',label:'Other'}
];
return '<div class="fi">'+

/* === Full-width Net Worth Hero with big chart === */
'<div class="hero dash-full" style="padding:24px 28px 20px">'+
'<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px"><div>'+
'<div style="font-size:13px;font-weight:400;opacity:0.85;letter-spacing:0.3px">Household Net Worth</div>'+
'<div style="font-size:48px;font-weight:800;letter-spacing:-3px;line-height:1.05;margin-top:4px;font-variant-numeric:tabular-nums">$82,450</div>'+
'<div class="r" style="margin-top:6px;gap:8px"><span style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.9)">+$320 today</span>'+bg('+1.2% this month','rgba(255,255,255,0.85)')+'<span style="font-size:12px;color:rgba(255,255,255,0.6)">+$10,050 YTD (+13.9%)</span></div>'+
'</div><div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px"><div style="display:flex;background:rgba(255,255,255,0.1);border-radius:10px;border:1px solid rgba(255,255,255,0.12);overflow:hidden">'+['7D','30D','90D','1Y','All'].map(function(r,i){return '<button onclick="toggleHeroRange(this)" style="padding:8px 14px;font-size:11px;font-weight:700;color:rgba(255,255,255,'+(i===3?1:0.5)+');background:'+(i===3?'rgba(255,255,255,0.15)':'transparent')+';min-height:36px">'+r+'</button>'}).join('')+'</div>'+
'<div style="display:grid;grid-template-columns:repeat(3,auto);gap:16px;text-align:right;margin-top:4px">'+
'<div><div style="font-size:10px;opacity:0.6">Assets</div><div style="font-size:16px;font-weight:800">$85,650</div></div>'+
'<div><div style="font-size:10px;opacity:0.6">Liabilities</div><div style="font-size:16px;font-weight:800">$3,200</div></div>'+
'<div><div style="font-size:10px;opacity:0.6">Savings Rate</div><div style="font-size:16px;font-weight:800">39%</div></div>'+
'</div></div></div>'+
'<div style="margin-top:4px">'+svgLineChart(nwChartData,700,140,'rgba(255,255,255,0.8)','12-Month Net Worth',true)+'</div>'+
'</div>'+

/* === 4 stat cards row === */
'<div class="stat-row cols-4">'+
'<div class="stat-card" style="cursor:pointer" onclick="os(\'Flex Budget\',sFlexBudget())"><div class="stat-label">Safe to Spend</div><div class="stat-value" style="color:var(--pos)">$1,680</div><div class="stat-change up">$140/day for 12 more days</div>'+br(63,'var(--pos)',4)+'</div>'+
'<div class="stat-card" style="cursor:pointer" onclick="gt(\'budget\')"><div class="stat-label">Spent This Month</div><div class="stat-value">$2,920</div><div class="stat-change down">'+trendIndicator(2920,2480,'','')+'vs last month</div></div>'+
'<div class="stat-card" style="cursor:pointer" onclick="gt(\'goals\')"><div class="stat-label">Saved This Month</div><div class="stat-value" style="color:var(--acc)">$2,760</div><div class="stat-change up">39% rate &mdash; beating 35% goal</div></div>'+
'<div class="stat-card" style="cursor:pointer" onclick="os(\'Financial Health\',sHS())"><div class="stat-label">Financial Wellness</div><div class="stat-value">'+wellnessScore+'<span style="font-size:14px;color:var(--t2)">/100</span></div><div class="stat-change up">Good &mdash; 3 actions to improve</div></div>'+
'</div>'+

/* === Quick Links / Tools Grid === */
'<div class="dash-full" style="margin-bottom:16px"><div style="font-size:13px;font-weight:700;margin-bottom:8px">Quick Links &amp; Tools</div>'+quickLinksGrid()+'</div>'+

/* === Two column layout === */
'<div class="dash-row">'+

/* LEFT COLUMN */
'<div class="dash-main">'+

/* Spending by Category donut */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Where Your Money Goes</span><span class="view-all" onclick="gt(\'budget\')">View Budget &rarr;</span></div>'+
'<div class="chart-subtitle">April spending across all categories</div>'+
svgDonut(spendDonutSegs,160,'$2,920','this month')+
'</div>'+

/* Spending Trends (Mint feature) */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Your Spending Over Time</span><span class="view-all" onclick="gp(\'spending\')">Details &rarr;</span></div>'+
'<div class="chart-subtitle">Groceries &amp; dining trending down 8% from last month</div>'+
svgStackedBarChart(monthlySpending,500,180,
  ['g','d','s','e','t'],
  ['var(--pos)','var(--warn)','var(--neg)','var(--acc)','var(--info)'],
  ['Groceries','Dining','Shopping','Entertainment','Transport'])+
'</div>'+

/* Recent Transactions Table (10 items) */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Your Latest Transactions</span><span class="view-all" onclick="gp(\'transactions\')">View All &rarr;</span></div>'+
'<table class="data-table"><thead><tr><th>Who</th><th>Merchant</th><th>Category</th><th>Date</th><th style="text-align:right">Amount</th></tr></thead><tbody>'+
[{w:'V',n:'Whole Foods',c:'Groceries',a:'-$67.43',t:'Today'},
{w:'C',n:'TreatYoSelf',c:'Clothing',a:'-$650.00',t:'Yesterday',f:true},
{w:'V',n:'Shell Gas',c:'Transport',a:'-$48.20',t:'Yesterday'},
{w:'J',n:'Mortgage',c:'Housing',a:'-$2,000',t:'Friday'},
{w:'C',n:'Target Refund',c:'Refund',a:'+$84.50',t:'Apr 10',rf:true},
{w:'V',n:'Netflix',c:'Subscriptions',a:'-$15.49',t:'Apr 10'},
{w:'C',n:'Amazon',c:'Shopping',a:'-$150.00',t:'Apr 10'},
{w:'V',n:'ALTA Payroll',c:'Income',a:'+$4,280',t:'Apr 11',inc:true},
{w:'V',n:'Costco',c:'Groceries',a:'-$124.30',t:'Apr 8'},
{w:'C',n:'Starbucks',c:'Dining',a:'-$6.75',t:'Apr 8'}
].map(function(tx){return '<tr style="cursor:pointer" onclick="os(\'Transaction\',sTx(\''+tx.n+'\',\''+tx.a+'\',\''+tx.c+'\',\''+tx.w+'\'))"><td>'+av(tx.w,22,tx.w==='C'?'var(--warn)':tx.w==='J'?'var(--info)':'var(--acc)')+'</td><td><span style="font-weight:600">'+tx.n+'</span>'+(tx.f?' '+bg('FLAG','var(--neg)'):'')+(tx.rf?' '+bg('Refund','var(--pos)'):'')+(tx.inc?' '+bg('INCOME','var(--pos)'):'')+'</td><td style="color:var(--t2)">'+tx.c+'</td><td style="color:var(--t2)">'+tx.t+'</td><td class="amount" style="color:'+(tx.inc||tx.rf?'var(--pos)':tx.f?'var(--neg)':'var(--t1)')+'">'+tx.a+'</td></tr>'}).join('')+
'</tbody></table></div>'+

/* Upcoming Bills */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Bills Coming Up</span><span class="view-all" onclick="gp(\'billscalendar\')">Calendar &rarr;</span></div>'+
'<table class="data-table"><thead><tr><th>Bill</th><th>Due</th><th>Status</th><th style="text-align:right">Amount</th></tr></thead><tbody>'+
[{n:'Electric Bill',a:'$145',d:'Tomorrow',at:false},{n:'Internet',a:'$89',d:'Apr 15',at:true},{n:'Car Payment',a:'$385',d:'Apr 15',at:true},{n:'Phone',a:'$140',d:'Apr 18',at:true},{n:'Gym',a:'$50',d:'Apr 20',at:true}].map(function(b){
return '<tr style="cursor:pointer" onclick="os(\''+b.n+'\',sBill(\''+b.n+'\','+parseInt(b.a.replace('$',''))+','+b.at+',\''+b.d+'\'))"><td style="font-weight:600">'+b.n+'</td><td style="color:var(--t2)">'+b.d+'</td><td>'+(b.at?bg('Autopay','var(--pos)'):bg('Manual','var(--warn)'))+'</td><td class="amount">'+b.a+'</td></tr>'}).join('')+
'</tbody></table></div>'+

'</div>'+/* end dash-main */

/* RIGHT COLUMN */
'<div class="dash-side">'+

/* Financial Wellness Score */
