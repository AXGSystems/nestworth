    {id:'audit',label:'Audit Trail',iconPath:icons.shield},
    {id:'billaudit',label:'Bill Audit',iconPath:icons.scissors},
    {id:'billscalendar',label:'Bills Calendar',iconPath:icons.calendar},
    {id:'chargeiq',label:'ChargeIQ',iconPath:icons.search},
    {id:'credithealth',label:'Credit Health',iconPath:icons.gauge},
    {id:'debtpaydown',label:'Debt Paydown',iconPath:'<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>'},
    {id:'emergencyfund',label:'Emergency Fund',iconPath:icons.shield},
    {id:'exportdata',label:'Export Data',iconPath:icons.download},
    {id:'feeanalyzer',label:'Fee Analyzer',iconPath:icons.trending},
    {id:'incomecadence',label:'Income Cadence',iconPath:'<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>'},
    {id:'messages',label:'Messages',iconPath:icons.msg},
    {id:'moneydate',label:'Money Date',iconPath:icons.heart},
    {id:'nestworthscore',label:'NestWorth Score',iconPath:icons.barChart2},
    {id:'nests',label:'Nests',iconPath:'<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>'},
    {id:'partnertransparency',label:'Partner Transparency',iconPath:icons.shield},
    {id:'scanner',label:'Receipt Scanner',iconPath:icons.cam},
    {id:'spending',label:'Spending',iconPath:icons.activity},
    {id:'subscriptions',label:'Subscriptions',iconPath:icons.scissors},
    {id:'synchealth',label:'Sync Health',iconPath:icons.refreshCw},
    {id:'taxdeductions',label:'Tax Deductions',iconPath:icons.receipt},
    {id:'transactions',label:'Transactions',iconPath:icons.activity},
    {id:'weatherforecast',label:'Weather Forecast',iconPath:icons.cloudSun},
  ],
  support:[
    {id:'featurerequest',label:'Feature Request',iconPath:icons.lightbulb},
    {id:'reportbug',label:'Report Bug',iconPath:icons.bug},
  ],
  settings:[
    {id:'settings',label:'Settings',iconPath:'<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>'},
  ],
};

function renderDrawerSection(title,items,isNav){
  var h='<div class="drawer-section"><div class="drawer-section-title">'+title+'</div>';
  items.forEach(function(item){
    var active=(isNav && ct===item.id && !pg) || (!isNav && pg===item.id);
    var icHtml;
    if(item.icon && icons[item.icon]){
      icHtml=icons[item.icon](active?'var(--acc)':'var(--t2)',active);
    } else {
      icHtml=ic(item.iconPath||icons.chev,18,active?'var(--acc)':'var(--t2)',1.5);
    }
    h+='<div class="drawer-item'+(active?' active':'')+'" onclick="'+(isNav?"gt('"+item.id+"')":"gp('"+item.id+"')")+'">'+icHtml+'<span>'+item.label+'</span></div>';
  });
  h+='</div>';
  return h;
}

function buildDrawer(){
  var d=$('drawer');
  if(!d)return;
  d.innerHTML='<div class="drawer-header"><div style="display:flex;align-items:center;gap:8px"><div style="width:32px;height:32px;border-radius:16px;background:linear-gradient(135deg,var(--gold),var(--acc));display:flex;align-items:center;justify-content:center"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="13" rx="9" ry="7" stroke="#fff" stroke-width="2.2"/><path d="M8 11c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg></div><div><div style="font-size:16px;font-weight:800;letter-spacing:-0.3px"><span style="color:var(--t1)">Nest</span><span style="color:var(--gold)">Worth</span></div><div class="sub" style="font-size:10px">v4.2</div></div></div><button onclick="closeDrawer()" aria-label="Close menu" style="width:44px;height:44px;display:flex;align-items:center;justify-content:center;margin-left:auto">'+ic('<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',20,'var(--t2)',2)+'</button></div>'+
  renderDrawerSection('Main',drawerItems.main,true)+
  renderDrawerSection('Features A\u2013Z',drawerItems.features,false)+
  renderDrawerSection('Support',drawerItems.support,false)+
  renderDrawerSection('Settings & Account',drawerItems.settings,false);
}

function _sbItem(item,isNav){
  var active=(isNav && ct===item.id && !pg) || (!isNav && pg===item.id);
  var icHtml;
  if(item.icon && icons[item.icon]){
    icHtml=icons[item.icon](active?'var(--acc)':'var(--t2)',active);
  } else {
    icHtml=ic(item.iconPath||icons.chev,18,active?'var(--acc)':'var(--t2)',1.5);
  }
  return '<div class="sb-item'+(active?' active':'')+'" onclick="'+(isNav?"gt('"+item.id+"')":"gp('"+item.id+"')")+'">'+icHtml+'<span class="sb-label">'+item.label+'</span></div>';
}
function _sbSection(title,items,isNav){
  var h='<div class="sb-section"><div class="sb-section-title">'+title+'</div>';
  items.forEach(function(item){h+=_sbItem(item,isNav)});
  return h+'</div>';
}
function buildSidebar(){
  var sb=$('sidebar');
  if(!sb)return;
  sb.classList.toggle('collapsed',sidebarCollapsed);

  sb.innerHTML='<div class="sidebar-header"><div class="sidebar-header-text" style="display:flex;align-items:center;gap:8px"><div style="width:28px;height:28px;border-radius:14px;background:linear-gradient(135deg,var(--gold),var(--acc));display:flex;align-items:center;justify-content:center"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="13" rx="9" ry="7" stroke="#fff" stroke-width="2.2"/><path d="M8 11c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg></div><div style="font-size:15px;font-weight:800;letter-spacing:-0.3px"><span>Nest</span><span style="color:var(--gold)">Worth</span></div></div><button onclick="toggleSidebar()" aria-label="Toggle sidebar" style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:8px;transition:background var(--fast) ease" onmouseover="this.style.background=\'var(--accS)\'" onmouseout="this.style.background=\'transparent\'">'+ic(icons.sidebar,16,'var(--t2)',1.5)+'</button></div>'+
  _sbSection('Main',drawerItems.main,true)+
  _sbSection('Features A\u2013Z',drawerItems.features,false)+
  _sbSection('Support',drawerItems.support,false)+
  _sbSection('Settings & Account',drawerItems.settings,false);
}


/* ========== PAGE ROUTER ========== */
function getPageContent(){
  if(pg){
    switch(pg){
      case 'settings': return rSettings();
      case 'accounts': return rAccounts();
      case 'messages': return rMessages();
      case 'scanner': return rScanner();
      case 'achievements': return rAchievements();
      case 'alerts': return rAlerts();
      case 'audit': return rPartnerTransparency();
      case 'billaudit': return rBillAudit();
      case 'billscalendar': return rBillsCalendar();
      case 'chargeiq': return rChargeIQ();
      case 'credithealth': return rCreditHealth();
      case 'debtpaydown': return rDebtPaydown();
      case 'emergencyfund': return rEmergencyFund();
      case 'exportdata': return rExportData();
      case 'feeanalyzer': return rFeeAnalyzer();
      case 'incomecadence': return rIncomeCadence();
      case 'moneydate': return rMoneyDate();
      case 'nestworthscore': return rNestWorthScore();
      case 'nests': return rNests();
      case 'partnertransparency': return rPartnerTransparency();
      case 'spending': return rSpending();
      case 'subscriptions': return rSubscriptions();
      case 'synchealth': return rSyncHealth();
      case 'taxdeductions': return rTaxDeductions();
      case 'transactions': return rTransactions();
      case 'weatherforecast': return rWeatherForecast();
      case 'featurerequest': return rFeatureRequest();
      case 'reportbug': return rReportBug();
      default: return rHome();
    }
  }
  switch(ct){
    case 'home': return rHome();
    case 'budget': return rBudget();
    case 'goals': return rGoals();
    case 'track': return rTrack();
    case 'coach': return rCoach();
    default: return rHome();
  }
}


/* ========== RENDER ENGINE ========== */
var _prevTab='',_prevPg=null;
function rr(){
  /* Header */
  var h=$('ahd');
  var showingHome=(ct==='home'&&!pg);
  var pageTitle=pg?pg.charAt(0).toUpperCase()+pg.slice(1).replace(/([A-Z])/g,' $1'):ct.charAt(0).toUpperCase()+ct.slice(1);

  h.innerHTML=
    '<div class="r" style="gap:7px">'+
    '<button class="hamburger-btn" onclick="openDrawer()" aria-label="Open menu" style="width:44px;height:44px;border-radius:22px;display:flex;align-items:center;justify-content:center">'+icons.menu('var(--t2)')+'</button>'+
    (showingHome?
      '<div style="width:28px;height:28px;border-radius:14px;background:linear-gradient(135deg,var(--gold),var(--acc));display:flex;align-items:center;justify-content:center"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="13" rx="9" ry="7" stroke="#fff" stroke-width="2.2"/><path d="M8 11c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg></div><div style="font-size:18px;font-weight:800;letter-spacing:-0.5px"><span style="color:var(--t1)">Nest</span><span style="color:var(--gold)">Worth</span></div>'
      :'<span style="font-size:16px;font-weight:700;letter-spacing:-0.3px">'+pageTitle+'</span>')+
    '</div>'+
    '<div class="r" style="gap:2px">'+
    av('V',22,'var(--acc)')+av('C',22,'var(--warn)')+
    '<button onclick="gp(\'settings\')" aria-label="Settings" style="width:44px;height:44px;border-radius:22px;display:flex;align-items:center;justify-content:center"><div style="width:32px;height:32px;border-radius:16px;background:var(--accS);display:flex;align-items:center;justify-content:center">'+icons.gear('var(--t2)')+'</div></button>'+
    '<button onclick="os(\'Notifications\',sNotifs())" aria-label="Notifications" style="position:relative;width:44px;height:44px;border-radius:22px;display:flex;align-items:center;justify-content:center"><div style="width:32px;height:32px;border-radius:16px;background:var(--accS);display:flex;align-items:center;justify-content:center">'+icons.bell('var(--t2)')+'</div><div class="alert-dot" style="top:6px;right:6px"></div></button>'+
    '</div>';

  /* Content */
  $('cnt').innerHTML=getPageContent();

  /* Accessibility: auto-label chart containers and icon-only buttons */
  document.querySelectorAll('.chart-container').forEach(function(el){
    if(!el.getAttribute('aria-label')){
      var title=el.querySelector('.chart-title,.shd');
      if(title)el.setAttribute('aria-label',title.textContent+' chart');
      el.setAttribute('role','img');
    }
  });

  /* Reset scroll position on navigation */
  var ma=document.querySelector('.main-area');
  if(ma)ma.scrollTop=0;
  if(!isDesktop())window.scrollTo(0,0);

  /* Tab bar (mobile only) */
  if(_prevTab!==ct||_prevPg!==pg){
    $('tbar').innerHTML=TABS.map(function(t){
      var a=ct===t&&!pg;
      var cl=a?'var(--acc)':'var(--t3)';
      return '<button class="tb '+(a?'a':'')+'" onclick="gt(\''+t+'\')" style="position:relative">'+icons[t](cl,a)+'<span>'+t.charAt(0).toUpperCase()+t.slice(1)+'</span></button>';
    }).join('');
    _prevTab=ct;_prevPg=pg;
  }

  /* Drawer & Sidebar */
  buildDrawer();
  buildSidebar();
}

/* Init */
rr();
updateThemeColor(theme);
requestAnimationFrame(function(){document.body.classList.add('loaded')});

/* Handle resize for responsive layout */
var _resizeTimer;
window.addEventListener('resize',function(){clearTimeout(_resizeTimer);_resizeTimer=setTimeout(function(){rr()},150)});

/* Escape key closes drawers/sheets */
document.addEventListener('keydown',function(e){if(e.key==='Escape'){if($('sho').classList.contains('open')){closeSheet()}else if(drawerOpen){closeDrawer()}}});

/* Mobile: scroll input into view when virtual keyboard opens */
document.addEventListener('focusin',function(e){if(!isDesktop()&&(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA')){setTimeout(function(){e.target.scrollIntoView({behavior:'smooth',block:'center'})},300)}});
</script>
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js')}</script>
</body>
</html>
