/* ========== WEATHER FORECAST — 90-Day Cash Flow ========== */
function rWeatherForecast(){
var forecast=[];
var balance=5360;
var incDays=[1,15,25];
var billDays=[1,5,10,15,18,20,25];
for(var d=1;d<=90;d++){
  var dayIncome=0,dayExp=0;
  if(d%14===0)dayIncome+=4280;
  if(d%30===0||d===1)dayIncome+=2800;
  dayExp=Math.round(Math.random()*80+20);
  if(d%30<=2)dayExp+=2000;
  if(d%15===0)dayExp+=400;
  balance=balance+dayIncome-dayExp;
  var weather=balance>8000?'sunny':balance>4000?'partly':balance>1500?'cloudy':'stormy';
  forecast.push({d:d,bal:balance,w:weather,inc:dayIncome,exp:dayExp});
}
var weeklyData=[];
for(var wk=0;wk<13;wk++){
  var idx=Math.min(wk*7,forecast.length-1);
  weeklyData.push({m:'W'+(wk+1),v:forecast[idx].bal});
}

if(isDesktop()){
return '<div class="fi">'+
'<div class="hero" style="margin-bottom:16px"><div class="r" style="gap:10px">'+ic(icons.cloudSun,24,'#fff',2)+'<div><div style="font-size:20px;font-weight:900">Financial Weather Forecast</div><div style="opacity:0.8;font-size:12px">See if financial storms are heading your way over the next 90 days</div></div></div></div>'+
'<div class="stat-row cols-4">'+
'<div class="stat-card" title="Sunny: Balance above $8,000 - cash flow is healthy"><div class="stat-label">Today\'s Forecast</div><div class="stat-value" style="color:var(--pos)">Sunny</div><div class="sub">Cash flow is healthy at $5,360</div></div>'+
'<div class="stat-card" title="Partly Cloudy: Balance between $4,000-$8,000"><div class="stat-label">30-Day Outlook</div><div class="stat-value" style="color:var(--acc)">Partly</div><div class="sub">Expected: $'+forecast[29].bal.toLocaleString()+'</div></div>'+
'<div class="stat-card" title="Cloudy: Balance between $1,500-$4,000 - watch spending"><div class="stat-label">60-Day</div><div class="stat-value" style="color:var(--warn)">Cloudy</div><div class="sub">Expected: $'+forecast[59].bal.toLocaleString()+'</div></div>'+
'<div class="stat-card"><div class="stat-label">90-Day</div><div class="stat-value" style="color:'+(forecast[89].bal>4000?'var(--pos)':'var(--neg)')+'">$'+forecast[89].bal.toLocaleString()+'</div></div>'+
'</div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container"><div class="chart-title">13-Week Cash Flow Outlook</div>'+
svgLineChart(weeklyData,600,200,'var(--acc)','Projected Balance')+'</div>'+
'<div class="chart-container"><div class="chart-title">Day-by-Day Forecast (Next 30 Days)</div>'+
'<div style="display:grid;grid-template-columns:repeat(10,1fr);gap:4px">'+
forecast.slice(0,30).map(function(f){var emoji=f.w==='sunny'?'&#9728;':f.w==='partly'?'&#9925;':f.w==='cloudy'?'&#9729;':'&#9928;';var col=f.w==='sunny'?'var(--pos)':f.w==='partly'?'var(--acc)':f.w==='cloudy'?'var(--warn)':'var(--neg)';var wLabel=f.w==='sunny'?'Sunny (>$8k)':f.w==='partly'?'Partly Cloudy ($4k-$8k)':f.w==='cloudy'?'Cloudy ($1.5k-$4k)':'Stormy (<$1.5k)';return '<div style="text-align:center;padding:4px;border-radius:6px;background:color-mix(in srgb,'+col+' 8%,transparent)" title="Day '+f.d+': '+wLabel+'. Balance: $'+f.bal.toLocaleString()+'"><div style="font-size:14px">'+emoji+'</div><div style="font-size:8px;font-weight:700;color:'+col+'">D'+f.d+'</div></div>'}).join('')+'</div></div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Storm Warnings</div>'+
(forecast.filter(function(f){return f.w==='stormy'}).length>0?
forecast.filter(function(f){return f.w==='stormy'}).slice(0,3).map(function(f){return '<div class="ci" style="margin-bottom:6px;background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent)"><div style="font-weight:700;font-size:12px;color:var(--neg)">Day '+f.d+': Stormy</div><div class="sub">Balance drops to $'+f.bal.toLocaleString()+'</div></div>'}).join(''):
'<div class="ci" style="background:var(--posBg)"><div style="font-weight:700;font-size:12px;color:var(--pos)">No danger zones detected</div><div class="sub">Cash flow looks healthy for 90 days</div></div>')+
'</div>'+
'<div class="chart-container"><div class="chart-title">Key Dates</div>'+
[{d:'Apr 25',e:'ALTA Payroll +$4,280'},{d:'May 1',e:'Mortgage -$2,000 + Rental +$1,200'},{d:'May 15',e:'Multiple bills due (-$600)'},{d:'Jun 1',e:'Major bill cycle restart'}].map(function(kd){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span style="font-size:10px;font-weight:700;width:48px">'+kd.d+'</span><span style="font-size:11px;flex:1">'+kd.e+'</span></div>'}).join('')+'</div>'+
'<div class="chart-container"><div class="chart-title">Weather Legend</div>'+
[{w:'Sunny',d:'Balance > $8k',c:'var(--pos)',e:'&#9728;'},{w:'Partly Cloudy',d:'$4k - $8k',c:'var(--acc)',e:'&#9925;'},{w:'Cloudy',d:'$1.5k - $4k',c:'var(--warn)',e:'&#9729;'},{w:'Stormy',d:'< $1.5k',c:'var(--neg)',e:'&#9928;'}].map(function(l){return '<div class="r" style="padding:4px 0;gap:6px"><span style="font-size:16px">'+l.e+'</span><span style="font-size:11px;font-weight:700;color:'+l.c+';flex:1">'+l.w+'</span><span class="sub">'+l.d+'</span></div>'}).join('')+'</div>'+
'</div></div>'+
relatedPages([{label:'Home',tab:'home'},{label:'Budget',tab:'budget'},{label:'Bills Calendar',pg:'billscalendar'},{label:'Income Cadence',pg:'incomecadence'},{label:'Emergency Fund',pg:'emergencyfund'}])+
'</div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs"><div class="r" style="gap:8px;margin-bottom:10px">'+ic(icons.cloudSun,20,'var(--acc)',2)+'<div style="font-weight:800;font-size:16px">Weather Forecast</div></div>'+
'<div style="text-align:center;margin-bottom:12px"><div style="font-size:40px">&#9728;</div><div style="font-size:20px;font-weight:900;color:var(--pos)">Sunny</div><div class="sub">Current balance healthy</div></div>'+
'<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:4px">'+
forecast.slice(0,10).map(function(f){var emoji=f.w==='sunny'?'&#9728;':f.w==='partly'?'&#9925;':f.w==='cloudy'?'&#9729;':'&#9928;';return '<div style="text-align:center;padding:4px"><div style="font-size:16px">'+emoji+'</div><div style="font-size:8px;font-weight:700">D'+f.d+'</div></div>'}).join('')+'</div></div></div>'}

/* ========== NESTWORTH SCORE (0-1000) ========== */
function rNestWorthScore(){
var totalScore=742;
var subScores=[{n:'Savings Rate',s:82,max:125,tip:'+15 pts: increase to 40%'},{n:'Debt Management',s:90,max:125,tip:'Great! Low debt ratio'},{n:'Budget Adherence',s:68,max:125,tip:'+12 pts: stay under in all categories'},{n:'Account Health',s:55,max:125,tip:'+35 pts: reconnect Cap One'},{n:'Emergency Fund',s:35,max:125,tip:'+45 pts: reach 3-month target'},{n:'Net Worth Growth',s:88,max:125,tip:'Strong upward trend'},{n:'Bill Optimization',s:72,max:125,tip:'+10 pts: complete bill audit'},{n:'Financial Habits',s:95,max:125,tip:'Excellent consistency'}];
var scoreHistory=[{m:'Jan',v:680},{m:'Feb',v:705},{m:'Mar',v:720},{m:'Apr',v:742}];
var improvements=[{action:'Reconnect Cap One Savings',impact:'+35',effort:'Easy'},{action:'Reach 3-month emergency fund',impact:'+45',effort:'Hard'},{action:'Stay under budget all categories',impact:'+12',effort:'Medium'},{action:'Complete bill audit actions',impact:'+10',effort:'Easy'},{action:'Increase savings rate to 40%',impact:'+15',effort:'Medium'}];

if(isDesktop()){
return '<div class="fi">'+
'<div class="hero" style="text-align:center;margin-bottom:16px;padding:18px 20px"><div style="font-size:13px;font-weight:600;opacity:0.8">Your NestWorth Score</div>'+
'<div style="width:130px;height:130px;border-radius:65px;background:conic-gradient(var(--pos) '+Math.round(totalScore/10)+'%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:10px auto"><div style="width:102px;height:102px;border-radius:51px;background:rgba(0,0,0,0.3);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;flex-direction:column;align-items:center;justify-content:center"><div style="font-size:36px;font-weight:900">'+totalScore+'</div><div style="font-size:10px;opacity:0.7">of 1,000</div></div></div>'+
'<div style="font-size:13px;font-weight:600;margin-top:4px">'+(totalScore>=800?'Excellent':totalScore>=650?'Good':totalScore>=500?'Fair':'Needs Work')+'</div></div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container"><div class="chart-title">What Makes Up Your Score</div>'+
subScores.map(function(s){var pct=Math.round(s.s/s.max*100);var col=pct>=80?'var(--pos)':pct>=50?'var(--warn)':'var(--neg)';return '<div style="margin-bottom:10px" title="'+s.n+': '+s.s+'/'+s.max+' ('+pct+'%). '+s.tip+'"><div class="r" style="margin-bottom:3px"><span style="font-weight:700;font-size:12px;flex:1">'+s.n+'</span><span style="font-size:12px;font-weight:800;color:'+col+'">'+s.s+'/'+s.max+'</span></div>'+br(pct,col,5)+'<div class="sub" style="margin-top:2px;font-size:10px">'+s.tip+'</div></div>'}).join('')+'</div>'+
'<div class="chart-container"><div class="chart-title">Score History</div>'+
svgLineChart(scoreHistory,500,160,'var(--pos)','NestWorth Score')+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Fastest Ways to Improve</div>'+
'<table class="data-table"><thead><tr><th>Action</th><th>Impact</th><th>Effort</th></tr></thead><tbody>'+
improvements.sort(function(a,b){return parseInt(b.impact)-parseInt(a.impact)}).map(function(imp){return '<tr><td style="font-weight:600">'+imp.action+'</td><td style="font-weight:800;color:var(--pos)">'+imp.impact+'</td><td>'+bg(imp.effort,imp.effort==='Easy'?'var(--pos)':imp.effort==='Medium'?'var(--warn)':'var(--neg)')+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container"><div class="chart-title">Score Distribution</div>'+
svgDonut(subScores.map(function(s,i){var colors=['var(--acc)','var(--pos)','var(--warn)','var(--neg)','var(--info)','var(--gold)','var(--accL)','var(--t2)'];return {label:s.n,value:s.s,color:colors[i%colors.length]}}),160,totalScore+'/1000','Score')+'</div>'+
'</div></div>'+
relatedPages([{label:'Credit Health',pg:'credithealth'},{label:'Budget',tab:'budget'},{label:'Goals',tab:'goals'},{label:'Sync Health',pg:'synchealth'},{label:'Bill Audit',pg:'billaudit'}])+
'</div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs" style="text-align:center;padding:20px"><div class="sub">Your NestWorth Score</div>'+
'<div style="width:100px;height:100px;border-radius:50px;background:conic-gradient(var(--pos) '+Math.round(totalScore/10)+'%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:12px auto"><div style="width:76px;height:76px;border-radius:38px;background:var(--bgE);display:flex;flex-direction:column;align-items:center;justify-content:center"><div style="font-size:28px;font-weight:900;color:var(--acc)">'+totalScore+'</div><div class="sub" style="font-size:9px">of 1,000</div></div></div></div>'+
'<div class="c">'+subScores.map(function(s){var pct=Math.round(s.s/s.max*100);return '<div style="margin-bottom:8px"><div class="r" style="margin-bottom:2px"><span style="font-size:11px;font-weight:600;flex:1">'+s.n+'</span><span style="font-size:11px;font-weight:800;color:'+(pct>=80?'var(--pos)':'var(--warn)')+'">'+s.s+'/'+s.max+'</span></div>'+br(pct,pct>=80?'var(--pos)':pct>=50?'var(--warn)':'var(--neg)',3)+'</div>'}).join('')+'</div></div>'}

/* ========== CREDIT HEALTH ========== */
function rCreditHealth(){
var currentScore=creditScoreHistory.length?creditScoreHistory[creditScoreHistory.length-1].score:0;
var factors=[{n:'Payment History',w:35,s:currentScore?'Excellent':'N/A',c:'var(--pos)',d:'On-time payments are the biggest factor'},{n:'Credit Utilization',w:30,s:currentScore?'Good':'N/A',c:'var(--acc)',d:'Keep below 30% of limits'},{n:'Length of History',w:15,s:currentScore?'Fair':'N/A',c:'var(--warn)',d:'Average age of accounts matters'},{n:'Credit Mix',w:10,s:currentScore?'Good':'N/A',c:'var(--acc)',d:'Mix of credit cards, loans, mortgage'},{n:'New Inquiries',w:10,s:currentScore?'Excellent':'N/A',c:'var(--pos)',d:'Few recent hard inquiries'}];

if(isDesktop()){
return '<div class="fi">'+
'<div class="hero" style="text-align:center;margin-bottom:16px;padding:18px 20px"><div style="font-size:13px;font-weight:600;opacity:0.8">Your Credit at a Glance</div>'+
(currentScore?'<div style="width:120px;height:120px;border-radius:60px;background:conic-gradient('+(currentScore>=740?'var(--pos)':currentScore>=670?'var(--warn)':'var(--neg)')+' '+Math.round((currentScore-300)/550*100)+'%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:10px auto"><div style="width:94px;height:94px;border-radius:47px;background:rgba(0,0,0,0.3);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);display:flex;flex-direction:column;align-items:center;justify-content:center"><div style="font-size:32px;font-weight:900">'+currentScore+'</div><div style="font-size:10px;opacity:0.7">300-850 scale</div></div></div>':'<div style="font-size:15px;margin:16px 0">Enter your credit score below to get started</div>')+
pendingBadge('TransUnion/Experian API partnership')+'</div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container"><div class="chart-title">Track Your Credit Score</div>'+
'<div class="sub" style="margin-bottom:10px">Paste your latest score from Credit Karma, Experian, or your bank app</div>'+
'<div class="r" style="gap:8px;margin-bottom:12px"><input id="creditScoreInput" type="number" min="300" max="850" placeholder="Enter score (300-850)" value="'+(currentScore||'')+'" style="flex:1;padding:12px 16px;border-radius:12px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:16px;font-weight:700;outline:none;color:var(--t1)"><select id="creditSource" style="padding:12px;border-radius:12px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:13px;color:var(--t1)"><option>Credit Karma</option><option>Experian</option><option>TransUnion</option><option>Bank App</option><option>Other</option></select><button class="btn" style="height:48px;padding:0 20px;border-radius:12px;font-size:13px" onclick="saveCreditScore()">Save</button></div>'+
'<div style="background:var(--sep);height:8px;border-radius:4px;position:relative;margin:20px 0"><div style="position:absolute;left:0;top:0;height:100%;border-radius:4px;background:linear-gradient(90deg,var(--neg),var(--warn) 40%,var(--pos) 75%);width:100%"></div>'+(currentScore?'<div style="position:absolute;top:-6px;left:'+Math.round((currentScore-300)/550*100)+'%;width:20px;height:20px;border-radius:10px;background:var(--bgE);border:3px solid var(--acc);transform:translateX(-50%)"></div>':'')+
'<div style="display:flex;justify-content:space-between;margin-top:12px"><span class="sub">300</span><span class="sub">500</span><span class="sub">670</span><span class="sub">740</span><span class="sub">850</span></div></div></div>'+
(creditScoreHistory.length>1?'<div class="chart-container"><div class="chart-title">Score History</div>'+svgLineChart(creditScoreHistory.map(function(h){return {m:h.date,v:h.score}}),500,160,'var(--acc)','Credit Score')+'</div>':'')+
'<div class="chart-container"><div class="chart-title">What Drives Your Score</div>'+
factors.map(function(f){return '<div style="margin-bottom:10px"><div class="r" style="margin-bottom:3px"><span style="font-weight:700;font-size:12px;flex:1">'+f.n+' ('+f.w+'%)</span><span style="font-weight:700;font-size:12px;color:'+f.c+'">'+f.s+'</span></div>'+br(f.w*2,f.c,5)+'<div class="sub" style="margin-top:2px;font-size:10px">'+f.d+'</div></div>'}).join('')+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Your Credit Habits</div>'+
[{n:'Check Credit Karma weekly',s:true},{n:'Review credit report annually',s:false},{n:'Set up fraud alerts',s:true},{n:'Monitor utilization ratio',s:true}].map(function(m){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep)">'+(m.s?ic(icons.check,12,'var(--pos)',3):ic('<circle cx="12" cy="12" r="10"/>',12,'var(--t3)',1.5))+'<span style="font-size:11px;flex:1;font-weight:600;margin-left:6px">'+m.n+'</span></div>'}).join('')+'</div>'+
'<div class="chart-container"><div class="chart-title">Free Credit Report Links</div>'+
'<div class="ci" style="margin-bottom:6px;cursor:pointer"><div style="font-weight:700;font-size:12px">AnnualCreditReport.com</div><div class="sub">Free yearly from all 3 bureaus</div></div>'+
'<div class="ci" style="margin-bottom:6px;cursor:pointer"><div style="font-weight:700;font-size:12px">Credit Karma</div><div class="sub">Free weekly TransUnion + Equifax</div></div>'+
'<div class="ci" style="cursor:pointer"><div style="font-weight:700;font-size:12px">Experian Free</div><div class="sub">Free Experian FICO score</div></div></div>'+
'<div class="chart-container"><div class="chart-title">Score Ranges</div>'+
[{r:'800-850',l:'Exceptional',c:'var(--pos)'},{r:'740-799',l:'Very Good',c:'var(--acc)'},{r:'670-739',l:'Good',c:'var(--warn)'},{r:'580-669',l:'Fair',c:'var(--neg)'},{r:'300-579',l:'Poor',c:'var(--neg)'}].map(function(sr){return '<div class="r" style="padding:4px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span style="font-size:11px;font-weight:700;color:'+sr.c+';width:60px">'+sr.r+'</span><span style="font-size:11px;flex:1">'+sr.l+'</span>'+(currentScore>=parseInt(sr.r.split('-')[0])&&currentScore<=parseInt(sr.r.split('-')[1])?bg('YOU','var(--acc)'):sr.r)+'</div>'}).join('')+'</div>'+
pendingBadge('TransUnion/Experian API partnership')+
'</div></div>'+
relatedPages([{label:'NestWorth Score',pg:'nestworthscore'},{label:'Debt Paydown',pg:'debtpaydown'},{label:'Fee Analyzer',pg:'feeanalyzer'},{label:'Accounts',pg:'accounts'},{label:'Goals',tab:'goals'}])+
'</div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs" style="text-align:center;padding:16px"><div style="font-weight:800;font-size:16px;margin-bottom:8px">Credit Health</div>'+
(currentScore?'<div style="width:80px;height:80px;border-radius:40px;background:conic-gradient('+(currentScore>=740?'var(--pos)':currentScore>=670?'var(--warn)':'var(--neg)')+' '+Math.round((currentScore-300)/550*100)+'%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:0 auto"><div style="width:60px;height:60px;border-radius:30px;background:var(--bgE);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;color:var(--acc)">'+currentScore+'</div></div>':'<div class="sub">Enter your score to get started</div>')+
'<div style="margin-top:12px"><input id="creditScoreInput" type="number" min="300" max="850" placeholder="Score (300-850)" value="'+(currentScore||'')+'" style="width:60%;padding:10px 14px;border-radius:12px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:14px;text-align:center;outline:none;color:var(--t1)"><button class="btn-gold" style="margin-left:6px;padding:10px 16px" onclick="saveCreditScore()">Save</button></div>'+
pendingBadge('TransUnion/Experian API partnership')+'</div>'+
'<div class="c">'+factors.map(function(f){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:11px;font-weight:600;flex:1">'+f.n+' ('+f.w+'%)</span><span style="font-size:11px;font-weight:700;color:'+f.c+'">'+f.s+'</span></div>'}).join('')+'</div></div>'}

function saveCreditScore(){
var inp=$('creditScoreInput');
if(!inp||!inp.value)return;
var score=parseInt(inp.value);
if(score<300||score>850){os('Error',sDone('Please enter a score between 300 and 850.'));return}
var src=$('creditSource');
creditScoreHistory.push({score:score,date:new Date().toISOString().slice(0,10),source:src?src.value:'Manual'});
saveCreditHistory();
os('Saved!',sDone('Credit score of '+score+' saved. Track changes over time by updating periodically.'));
}


/* ========== SHEET GENERATORS ========== */
function sDone(msg){return '<div style="text-align:center;padding:20px"><div style="width:48px;height:48px;border-radius:24px;background:var(--posBg);display:flex;align-items:center;justify-content:center;margin:0 auto">'+ic(icons.check,24,'var(--pos)',3)+'</div><div style="font-size:15px;font-weight:700;margin-top:12px;white-space:pre-line">'+esc(msg)+'</div></div>'}

function sFlexBudget(){return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:36px;font-weight:800;color:var(--pos);letter-spacing:-2px">$1,680</div><div class="sub">safe to spend through Apr 30</div></div>'+
'<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);gap:6px;margin-bottom:14px"><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Budget</div><div style="font-size:14px;font-weight:800">$4,600</div></div><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Spent</div><div style="font-size:14px;font-weight:800;color:var(--warn)">$2,920</div></div><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Per Day</div><div style="font-size:14px;font-weight:800;color:var(--pos)">$140</div></div></div>'+
br(63,'var(--pos)',8)+
'<div class="sub" style="margin-top:6px">12 days remaining &middot; $140/day safe spend rate</div>'+
'<div class="ci" style="margin-top:12px;background:var(--posBg)"><div style="font-weight:700;font-size:11px;margin-bottom:4px">YNAB-Style Insight</div><div class="sub" style="line-height:1.5">Every dollar has a job. Your "flex" money is what\'s left after bills ($2,400) and savings ($520) are covered.</div></div>'}

function sHS(){return '<div style="text-align:center;margin-bottom:16px"><div style="width:80px;height:80px;border-radius:40px;background:conic-gradient(var(--pos) 74%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:0 auto"><div style="width:60px;height:60px;border-radius:30px;background:var(--bgE);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:900;color:var(--acc)">74</div></div><div class="sub" style="margin-top:8px">Good — room for improvement</div></div>'+[{n:'Savings Rate',s:82},{n:'Debt Ratio',s:90},{n:'Account Health',s:55},{n:'Budget Adherence',s:60},{n:'Emergency Fund',s:28},{n:'Spending Velocity',s:65},{n:'Bill Payment',s:95},{n:'Net Worth Trend',s:88}].map(function(i){return '<div style="margin-bottom:8px"><div class="r" style="justify-content:space-between;margin-bottom:2px"><span style="font-size:11px;font-weight:600">'+i.n+'</span><span style="font-size:11px;font-weight:800;color:'+(i.s>=80?'var(--pos)':i.s>=50?'var(--warn)':'var(--neg)')+'">'+i.s+'/100</span></div>'+br(i.s,i.s>=80?'var(--pos)':i.s>=50?'var(--warn)':'var(--neg)',3)+'</div>'}).join('')+'<div class="ci" style="margin-top:12px;background:var(--posBg)"><div style="font-weight:700;font-size:11px;margin-bottom:4px">How to improve</div><div class="sub" style="line-height:1.5">1. Reconnect Cap One Savings (+15)<br>2. Get Shopping under cap (+5)<br>3. Build emergency fund (+20)</div></div>'}

function sVel(){return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:36px;font-weight:900;color:var(--neg)">38%</div><div class="sub">faster than your average week</div></div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-bottom:14px"><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">This Week</div><div style="font-size:18px;font-weight:800;color:var(--neg)">$1,066</div></div><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Avg Week</div><div style="font-size:18px;font-weight:800">$772</div></div></div><div class="sub" style="line-height:1.5">At this pace you\'ll spend $4,740 — $420 over budget. The TreatYoSelf $650 purchase is the primary driver.</div>'}

function sCat(n,a,m,v,c){var p=Math.round((a/m)*100);return '<div class="r" style="justify-content:space-between;margin-bottom:10px"><div><div style="font-size:24px;font-weight:800;color:'+(p>100?'var(--neg)':'var(--t1)')+'">$'+a+'</div><div class="sub">of $'+m+'</div></div><div style="font-size:20px;font-weight:800;color:'+(p>100?'var(--neg)':p>80?'var(--warn)':'var(--pos)')+'">'+p+'%</div></div>'+br(p,p>100?'var(--neg)':p>80?'var(--warn)':'var(--pos)',8)+'<div style="margin-top:14px;font-weight:700;font-size:12px;margin-bottom:8px">Per Person</div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px"><div class="ci" style="display:flex;align-items:center;gap:6px">'+av('V',22)+'<div><div style="font-size:10px;font-weight:700">Von</div><div style="font-size:16px;font-weight:800;color:var(--acc)">$'+v+'</div></div></div><div class="ci" style="display:flex;align-items:center;gap:6px">'+av('C',22,'var(--warn)')+'<div><div style="font-size:10px;font-weight:700">Caroline</div><div style="font-size:16px;font-weight:800;color:var(--warn)">$'+c+'</div></div></div></div>'}

function sTx(n,a,c,w){var wn=w==='V'?'Von':w==='C'?'Caroline':w==='J'?'Joint':'Transfer';return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:28px;font-weight:900">'+a+'</div><div style="font-size:15px;font-weight:700;margin-top:4px">'+n+'</div><div class="sub" style="margin-top:2px">'+c+' &middot; '+wn+'</div></div><div style="font-weight:700;font-size:12px;margin-bottom:8px">Actions</div>'+['Re-categorize','Split Transaction','Add Note','Tag Tax-Deductible','Flag for Review','Attach Receipt'].map(function(a2){return '<div class="tr"><span style="font-size:12px;font-weight:600;flex:1">'+a2+'</span>'+ic(icons.chev,14,'var(--t3)')+'</div>'}).join('')+'<div class="tr" style="cursor:pointer;background:var(--accS);border-radius:10px;margin-top:4px;padding:10px 12px" onclick="closeSheet();gp(\'chargeiq\')"><div style="display:flex;align-items:center;gap:8px;flex:1">'+ic(icons.search,16,'var(--acc)',2)+'<div><div style="font-weight:700;font-size:12px;color:var(--acc)">ChargeIQ</div><div class="sub">Identify this merchant</div></div></div>'+ic(icons.chev,14,'var(--acc)')+'</div><div style="margin-top:12px;font-weight:700;font-size:12px;margin-bottom:6px">Partner Notes</div><div class="ci" style="font-size:11px;color:var(--t2)">No notes yet.</div><div class="r" style="gap:6px;margin-top:8px"><input placeholder="Add a note..." style="flex:1;min-width:0;padding:10px 14px;border-radius:16px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:12px;outline:none;color:var(--t1)"><button class="btn-gold" style="padding:8px 14px;font-size:11px">Send</button></div>'}

function sDup(){return '<div class="ci" style="margin-bottom:8px;display:flex;align-items:center;gap:8px">'+av('V',26)+' <strong>Whole Foods</strong> -$67.43<div class="sub" style="margin-left:auto">2:15 PM</div></div><div class="ci" style="margin-bottom:14px;border-color:color-mix(in srgb,var(--warn) 15%,transparent);background:var(--warnBg);display:flex;align-items:center;gap:8px">'+av('V',26)+' <strong style="color:var(--warn)">Whole Foods</strong> -$67.43<div class="sub" style="margin-left:auto">2:17 PM</div></div><div class="sub" style="line-height:1.5;margin-bottom:14px">Same amount, same merchant, 2 minutes apart. Possible duplicate charge.</div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px"><button class="btn btn-full" style="border-radius:22px;height:44px;font-size:13px">Keep Both</button><button class="btn-danger btn-full" style="border-radius:22px;padding:12px;font-size:13px">Hide Duplicate</button></div>'}

function sNest(n,c,g){var p=Math.round((c/g)*100);return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:28px;font-weight:900;color:var(--acc)">$'+c.toLocaleString()+'</div><div class="sub">of $'+g.toLocaleString()+' &middot; '+p+'%</div></div>'+br(p,'var(--acc)',8)+'<div style="margin-top:14px;font-weight:700;font-size:12px;margin-bottom:8px">History</div>'+[{d:'Apr 11',a:'+$15',w:'Auto'},{d:'Apr 4',a:'+$15',w:'Auto'},{d:'Mar 28',a:'+$200',w:'Von'},{d:'Mar 21',a:'+$15',w:'Auto'}].map(function(h){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep)"><span class="sub" style="width:48px">'+h.d+'</span><span style="font-size:12px;font-weight:700;color:var(--pos);flex:1">'+h.a+'</span><span class="sub">'+h.w+'</span></div>'}).join('')+'<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-top:14px"><button class="btn-gold btn-full" style="padding:12px">Boost</button><button class="btn-outline btn-full">Settings</button></div>'}

function sNewNest(){return '<div style="text-align:center;margin-bottom:14px">'+ic(icons.plus,32,'var(--acc)',1.5)+'<div style="font-size:16px;font-weight:800;margin-top:8px">Create a New Nest</div></div><div style="margin-bottom:12px"><div class="sub" style="margin-bottom:4px">Name</div><input placeholder="e.g., Vacation, Car Fund..." style="width:100%;padding:12px 16px;border-radius:12px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:14px;outline:none;color:var(--t1)"></div><div style="margin-bottom:12px"><div class="sub" style="margin-bottom:4px">Goal Amount</div><input type="number" placeholder="$5,000" style="width:100%;padding:12px 16px;border-radius:12px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:14px;outline:none;color:var(--t1)"></div><div style="margin-bottom:14px"><div class="sub" style="margin-bottom:4px">Auto-Save</div><div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:4px">'+['$10/wk','$25/wk','$50/wk','Custom'].map(function(v,i){return '<button class="btn-pill" style="'+(i===1?'background:var(--acc);color:#fff':'')+'">'+v+'</button>'}).join('')+'</div></div><div style="margin-bottom:14px"><div class="sub" style="margin-bottom:4px">Shared with</div><div style="display:flex;gap:6px">'+['Both','Von Only','Caroline Only'].map(function(v,i){return '<button class="btn-pill" style="'+(i===0?'background:var(--acc);color:#fff':'')+'">'+v+'</button>'}).join('')+'</div></div><button class="btn btn-full" style="border-radius:22px;height:48px;font-size:15px">Create Nest</button>'}

function sFore(){return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:36px;font-weight:900;color:var(--pos)">$33,120</div><div class="sub">projected savings by Dec 2026</div></div>'+['May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].map(function(m,i){var v=2760*(i+2);return '<div class="r" style="padding:4px 0;border-bottom:0.5px solid var(--sep)"><span class="sub" style="width:36px">'+m+'</span><div style="flex:1">'+br(v/33120*100,'var(--pos)',3)+'</div><span style="font-size:11px;font-weight:700;color:var(--pos);width:50px;text-align:right">$'+v.toLocaleString()+'</span></div>'}).join('')+'<div class="ci" style="margin-top:12px;background:var(--posBg);font-size:11px;color:var(--t2);line-height:1.5">Based on $2,760/mo. Bill audit savings would push to $34,884.</div>'}

function sBill(n,a,at,d){return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:28px;font-weight:900">$'+a+'</div><div style="font-size:14px;font-weight:700;margin-top:4px">'+n+'</div><div class="sub">Due '+d+' &middot; '+(at?'Autopay on':'Manual')+'</div></div>'+['Mar','Feb','Jan','Dec'].map(function(m){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep)"><span class="sub" style="width:40px">'+m+'</span><span style="font-size:11px;font-weight:700;color:var(--pos)">$'+a+'</span><span style="margin-left:auto">'+bg('Paid','var(--pos)')+'</span></div>'}).join('')+(!at?'<button class="btn btn-full" style="margin-top:14px;border-radius:22px;height:48px;font-size:14px">Set Up Autopay</button>':'')}

function sEmer(){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:14px;font-weight:800;color:var(--warn)">0.8 months coverage</div><div class="sub">Recommended: 3\u20136 months</div></div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-bottom:14px"><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Monthly Expenses</div><div style="font-size:18px;font-weight:800">$4,320</div></div><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">3-Month Target</div><div style="font-size:18px;font-weight:800;color:var(--pos)">$12,960</div></div></div>'+br(28,'var(--warn)',8)+'<div style="margin-top:14px;font-weight:700;font-size:12px;margin-bottom:8px">How to get there faster</div>'+[{a:'Bump daily save to $20',i:'+$150/mo',t:'62 wk'},{a:'Add bill audit savings',i:'+$147/mo',t:'32 wk'},{a:'$500 boost now',i:'Immediate',t:'28 wk'}].map(function(i){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:11px;flex:1">'+i.a+'</span><span style="font-size:10px;color:var(--pos);margin-right:6px">'+i.i+'</span><span style="font-size:10px;font-weight:700">'+i.t+'</span></div>'}).join('')}

function sMD(){return '<div style="text-align:center;margin-bottom:14px">'+ic(icons.heart,32,'var(--gold)',1.5)+'<div style="font-size:16px;font-weight:800;margin-top:6px">Money Date Mode</div><div class="sub">Designed for sitting down together</div></div><div class="sub" style="line-height:1.6;margin-bottom:14px">Guided couples review: spending comparison, goal progress, upcoming decisions, and wins.</div>'+['Weekly spending comparison','Per-person breakdown','Goal check-ins','Upcoming decisions','Celebrate wins'].map(function(i){return '<div class="r" style="padding:4px 0;gap:6px">'+ic(icons.check,12,'var(--pos)',3)+'<span style="font-size:11px">'+i+'</span></div>'}).join('')+'<button class="btn btn-full" style="margin-top:14px;border-radius:22px;height:48px;font-size:14px">Start Money Date</button>'}

function sBudgetSheet(){var cats=[{n:'Housing',a:2400,s:2000,f:true},{n:'Groceries',a:800,s:480},{n:'Dining',a:300,s:280},{n:'Shopping',a:200,s:235,o:true},{n:'Entertainment',a:150,s:85},{n:'Transport',a:200,s:120},{n:'Subs',a:100,s:62},{n:'Health',a:150,s:45},{n:'Personal',a:200,s:90},{n:'Misc',a:100,s:30}];var tA=cats.reduce(function(a,c){return a+c.a},0),tS=cats.reduce(function(a,c){return a+c.s},0);return '<div class="r" style="justify-content:space-between;margin-bottom:6px"><div><div class="sub" style="font-size:10px">Budgeted</div><div style="font-size:20px;font-weight:800">$'+tA.toLocaleString()+'</div></div><div style="text-align:right"><div class="sub" style="font-size:10px">Spent</div><div style="font-size:20px;font-weight:800;color:var(--warn)">$'+tS.toLocaleString()+'</div></div></div>'+br((tS/tA)*100,'var(--warn)',6)+'<div style="font-size:10px;color:var(--pos);font-weight:600;margin-top:4px;margin-bottom:14px">$'+(tA-tS).toLocaleString()+' remaining</div>'+cats.map(function(c){var p=Math.round((c.s/c.a)*100);return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span style="font-size:11px;font-weight:600;width:70px">'+c.n+'</span><div style="flex:1">'+br(p,c.o?'var(--neg)':p>80?'var(--warn)':'var(--pos)',3)+'</div><span style="font-size:10px;font-weight:700;color:'+(c.o?'var(--neg)':'var(--t2)')+';width:65px;text-align:right">$'+c.s+'/$'+c.a+'</span>'+(c.o?bg('OVER','var(--neg)'):c.f?bg('Fixed','var(--t3)'):'')+'</div>'}).join('')+'<button class="btn-gold btn-full" style="margin-top:12px;padding:12px;font-size:13px;border-radius:22px">Edit Budget</button>'}

function sDebt(){return '<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-bottom:14px"><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Total</div><div style="font-size:20px;font-weight:800;color:var(--neg)">$3,200</div></div><div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">Min</div><div style="font-size:20px;font-weight:800">$85/mo</div></div></div>'+[{n:'Chase CC',b:1800,r:'22.99%'},{n:'Student Loan',b:1400,r:'5.5%'}].map(function(d){return '<div class="ci" style="margin-bottom:6px"><div class="r" style="justify-content:space-between;margin-bottom:3px"><span style="font-weight:700;font-size:12px">'+d.n+'</span><span style="font-weight:800;font-size:14px;color:var(--neg)">$'+d.b.toLocaleString()+'</span></div><div class="sub">'+d.r+' APR</div></div>'}).join('')+'<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-top:12px"><div class="ci" style="text-align:center;padding:10px"><div style="font-size:11px;font-weight:700">Avalanche</div><div class="sub" style="font-size:9px">Highest interest first</div><div style="font-size:16px;font-weight:800;color:var(--pos);margin-top:4px">7.5 mo</div></div><div class="ci" style="text-align:center;padding:10px"><div style="font-size:11px;font-weight:700">Snowball</div><div class="sub" style="font-size:9px">Smallest first</div><div style="font-size:16px;font-weight:800;margin-top:4px">8.2 mo</div></div></div>'}

function sRBillsContent(){var bills=[{n:'Mortgage',a:2000,d:'1st',at:true,pd:true},{n:'Insurance',a:184,d:'5th',at:true,pd:true},{n:'Electric',a:145,d:'10th',at:false},{n:'Water',a:65,d:'12th',at:false},{n:'Internet',a:89,d:'15th',at:true},{n:'Car Payment',a:385,d:'15th',at:true},{n:'Phone',a:140,d:'18th',at:true},{n:'Gym',a:50,d:'20th',at:true},{n:'Student Loans',a:320,d:'25th',at:true}];return hd('Bills Calendar')+'<div class="r" style="justify-content:space-between;margin-bottom:12px"><div><div class="sub" style="font-size:10px">Remaining</div><div style="font-size:20px;font-weight:800;color:var(--warn)">$'+bills.filter(function(b){return!b.pd}).reduce(function(a,b){return a+b.a},0).toLocaleString()+'</div></div><div style="text-align:right"><div class="sub" style="font-size:10px">Paid</div><div style="font-size:20px;font-weight:800;color:var(--pos)">$'+bills.filter(function(b){return b.pd}).reduce(function(a,b){return a+b.a},0).toLocaleString()+'</div></div></div>'+bills.map(function(b){return '<div class="r" style="padding:7px 0;border-bottom:0.5px solid var(--sep);gap:6px"><div style="width:30px;text-align:center;flex-shrink:0"><div style="font-size:14px;font-weight:800;color:'+(b.pd?'var(--pos)':'var(--t1)')+'">'+b.d+'</div></div><div style="flex:1"><div class="r" style="gap:3px"><span style="font-weight:600;font-size:12px">'+b.n+'</span>'+(b.at?bg('Auto','var(--pos)'):bg('Manual','var(--warn)'))+'</div></div><div style="text-align:right;flex-shrink:0"><div style="font-weight:800;font-size:13px;color:'+(b.pd?'var(--pos)':'var(--t1)')+'">$'+b.a+'</div><div style="font-size:9px;color:'+(b.pd?'var(--pos)':'var(--warn)')+';font-weight:600">'+(b.pd?'Paid':'Due')+'</div></div></div>'}).join('')}

function sBillA(n,sv){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:28px;font-weight:900;color:var(--pos)">-$'+sv+'/mo</div><div class="sub">'+n+'</div><div class="sub" style="margin-top:4px">Annual: $'+(sv*12)+'</div></div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px"><button class="btn btn-full" style="border-radius:22px;height:44px;font-size:13px">Take Action</button><button class="btn-outline btn-full" style="border-radius:22px">Dismiss</button></div>'+pendingBadge('bill negotiation concierge')}
function sSub(n,a,w,i){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:24px;font-weight:900">$'+a+'/mo</div><div style="font-size:14px;font-weight:700;margin-top:4px">'+n+'</div><div class="sub">Used by: '+w+'</div>'+(i?'<div style="margin-top:6px">'+bg(i,'var(--neg)')+'</div>':'')+'</div>'+(i?'<div class="ci" style="background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);margin-bottom:10px;font-size:11px;color:var(--neg);font-weight:700">Low/no usage detected. Cancel = $'+(a*12).toFixed(0)+'/yr saved.</div><button class="btn-danger btn-full" style="border-radius:22px;padding:12px;font-size:13px;font-weight:700">Cancel Subscription</button>'+pendingBadge('subscription cancellation service'):'')}
function sTax(){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:28px;font-weight:900;color:var(--pos)">$1,240</div><div class="sub">YTD tax-deductible</div></div>'+[{n:'Goodwill Donation',a:'$450',c:'Charitable'},{n:'Medical Copays',a:'$320',c:'Medical'},{n:'Home Office',a:'$180',c:'Business'},{n:'Professional Dev',a:'$150',c:'Education'},{n:'Tax Prep',a:'$140',c:'Tax'}].map(function(t){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:11px;flex:1">'+t.n+'</span>'+bg(t.c,'var(--info)')+'<span style="font-size:11px;font-weight:700;margin-left:8px">'+t.a+'</span></div>'}).join('')}
function sFees(){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:36px;font-weight:900;color:var(--warn)">0.42%</div><div class="sub">weighted avg expense ratio</div></div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);gap:6px;margin-bottom:14px">'+[{l:'7yr',v:'$5,400'},{l:'15yr',v:'$18,200'},{l:'30yr',v:'$47,000'}].map(function(p){return '<div class="ci" style="text-align:center"><div class="sub" style="font-size:9px">'+p.l+' drag</div><div style="font-size:14px;font-weight:800;color:var(--neg)">'+p.v+'</div></div>'}).join('')+'</div>'+[{n:'Ally Invest',r:'0.08%',v:'$180.5k',q:'Low'},{n:'401(k) Funds',r:'0.65%',v:'$68.4k',q:'High'},{n:'Target Date',r:'0.35%',v:'$41.1k',q:'Med'}].map(function(f){return '<div class="ci" style="margin-bottom:4px;display:flex;align-items:center;gap:8px"><div style="flex:1"><div class="r" style="gap:3px"><span style="font-weight:700;font-size:11px">'+f.n+'</span>'+bg(f.q,f.q==='Low'?'var(--pos)':f.q==='High'?'var(--neg)':'var(--warn)')+'</div><div class="sub">'+f.r+' &middot; '+f.v+'</div></div></div>'}).join('')+'<div class="ci" style="margin-top:10px;background:var(--posBg)"><div style="font-weight:700;font-size:11px;margin-bottom:4px">Recommendation</div><div class="sub" style="line-height:1.5">Switching 401(k) to index funds at 0.10% would save $31,000 over 30 years.</div></div>'}

function sSyncD(b,l,s,v){return '<div style="text-align:center;margin-bottom:14px"><div class="dot" style="width:12px;height:12px;background:'+(s==='g'?'var(--pos)':s==='y'?'var(--warn)':'var(--neg)')+';margin:0 auto 8px"></div><div style="font-size:18px;font-weight:800">'+b+'</div><div class="sub">Last synced: '+l+' ago</div><div style="font-size:24px;font-weight:900;color:'+(s==='r'?'var(--neg)':'var(--t1)')+';margin-top:6px">'+v+'</div></div>'+(s==='r'?'<div class="ci" style="background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);margin-bottom:10px;font-size:11px;color:var(--neg);font-weight:700;line-height:1.5">47 days without sync. Balance may be inaccurate.</div><button class="btn btn-full" style="margin-top:8px;border-radius:22px;height:48px;font-size:14px">Force Reconnect</button>'+pendingBadge('Plaid integration'):'<div class="ci" style="background:var(--posBg);font-size:11px;color:var(--pos)">Syncing normally.</div>')}

function sDel(){return '<div class="ci" style="background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);margin-bottom:12px;font-size:11px;color:var(--t2);line-height:1.5">In Monarch, deleted transactions vanish. NestWorth logs every deletion and lets you restore.</div>'+[{n:'Target',a:'$84.50',w:'Caroline',t:'Mar 10'},{n:'Uber Eats',a:'$32.00',w:'Caroline',t:'Feb 28'},{n:'Cash Withdrawal',a:'$200',w:'Von',t:'Feb 15'}].map(function(d){return '<div class="ci" style="margin-bottom:8px;border-color:color-mix(in srgb,var(--neg) 12%,transparent)"><div class="r" style="margin-bottom:4px"><div style="flex:1"><div style="font-weight:700;font-size:13px;color:var(--neg)">'+d.n+' \u2014 '+d.a+'</div></div>'+bg('DELETED','var(--neg)')+'</div><div class="sub">Deleted by <strong>'+d.w+'</strong> on '+d.t+'</div><button class="btn-pill" style="margin-top:8px;background:var(--posBg);color:var(--pos)">Restore</button></div>'}).join('')}

function sNotes(){return '<div class="sub" style="margin-bottom:14px">Both partners can comment on any transaction.</div>'+[{tx:'TreatYoSelf \u2014 $650',ns:[{w:'V',t:'Was this planned?'},{w:'C',t:'Birthday gift for mom'}]},{tx:'Chase to Ally \u2014 $500',ns:[{w:'V',t:'Moving to higher APY'}]}].map(function(th){return '<div class="ci" style="margin-bottom:8px"><div style="font-weight:700;font-size:12px;margin-bottom:6px">'+th.tx+'</div>'+th.ns.map(function(n){return '<div class="r" style="gap:6px;margin-bottom:4px">'+av(n.w,18,n.w==='V'?'var(--acc)':'var(--warn)')+'<div style="flex:1;background:var(--accS);border-radius:10px;padding:6px 10px"><div style="font-size:10px;font-weight:600">'+(n.w==='V'?'Von':'Caroline')+'</div><div class="sub">'+n.t+'</div></div></div>'}).join('')+'</div>'}).join('')}

function sAuditDetail(a,d,w,t,f){return '<div style="text-align:center;margin-bottom:14px"><div style="width:48px;height:48px;border-radius:24px;background:'+(f?'var(--negBg)':'var(--posBg)')+';display:flex;align-items:center;justify-content:center;margin:0 auto">'+(f?ic(icons.flag,20,'var(--neg)',1.5):ic(icons.check,20,'var(--pos)',3))+'</div><div style="font-size:16px;font-weight:800;margin-top:8px;color:'+(f?'var(--neg)':'var(--t1)')+'">'+a+'</div><div class="sub" style="margin-top:4px">'+d+' &middot; '+w+' &middot; '+t+'</div></div>'+(f?'<div class="ci" style="background:var(--negBg);font-size:11px;color:var(--neg);font-weight:600;line-height:1.5">This action was flagged because it may affect household financial visibility. Both partners have been notified.</div>':'<div class="ci" style="background:var(--posBg);font-size:11px;color:var(--pos);line-height:1.5">This action is logged in the audit trail. No issues detected.</div>')}

function sAutoRule(t,d,v){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:20px;font-weight:800">'+t+'</div><div class="sub" style="margin-top:4px">'+d+' &middot; '+v+'</div></div><div class="ci" style="margin-bottom:8px"><div style="font-weight:700;font-size:12px;margin-bottom:4px">How it works</div><div class="sub" style="line-height:1.5">'+(t==='Round-Ups'?'Every purchase is rounded up to the nearest dollar. The difference goes to savings. Average $45/month.':t==='Set & Forget'?'A fixed amount is moved to savings every day. Pauses automatically if balance drops below $500.':'This rule runs automatically based on your settings. Adjust anytime.')+'</div></div><div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;margin-top:12px"><button class="btn btn-full" style="border-radius:22px;height:44px;font-size:13px">Edit Rule</button><button class="btn-outline btn-full" style="border-radius:22px">Pause</button></div>'}

function sAchieve(){return '<div style="text-align:center;margin-bottom:16px"><div style="font-size:36px;font-weight:900;color:var(--gold)">14</div><div class="sub">day streak under budget</div></div>'+[{n:'Budget Streak',d:'14 days under budget',done:true},{n:'First Nest',d:'Created first savings goal',done:true},{n:'$1k Saved',d:'Auto-saved over $1,000',done:true},{n:'$5k Saved',d:'Auto-saved over $5,000',done:true},{n:'Net Worth $100k',d:'Reach $100k net worth',done:false,p:82},{n:'3-Month Fund',d:'Emergency fund covers 3 months',done:false,p:28},{n:'Debt Free',d:'Pay off all consumer debt',done:false,p:65}].map(function(a){return '<div class="ci" style="margin-bottom:4px;display:flex;align-items:center;gap:10px;'+(!a.done?'opacity:0.6':'')+'"><div style="width:28px;height:28px;border-radius:14px;background:'+(a.done?'var(--gold)':'var(--sep)')+';display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#fff;font-size:12px">'+(a.done?ic(icons.check,12,'#fff',3):(a.p||0)+'%')+'</div><div style="flex:1"><div style="font-weight:700;font-size:12px">'+a.n+'</div><div class="sub">'+a.d+'</div></div>'+(!a.done&&a.p?'<div style="width:40px">'+br(a.p,'var(--acc)',3)+'</div>':'')+'</div>'}).join('')}

function sCon(){return '<div style="text-align:center;margin-bottom:14px"><div style="font-size:16px;font-weight:800">Connect a Bank</div><div class="sub">Secured by Plaid &middot; 256-bit</div></div>'+pendingBadge('Plaid integration')+'<input placeholder="Search 13,000+ institutions..." style="width:100%;padding:12px 16px;border-radius:16px;border:0.5px solid var(--sep);background:var(--cardBg);font-size:13px;outline:none;color:var(--t1);margin:12px 0">'+['Chase','Bank of America','Wells Fargo','Capital One','Citi','Ally','Fidelity','Vanguard','Schwab','USAA'].map(function(b){return '<div class="ci" style="margin-bottom:4px;display:flex;align-items:center;gap:8px;cursor:pointer;padding:10px 12px">'+ic(icons.grid,14,'var(--t2)',1.5)+'<span style="flex:1;font-weight:600;font-size:13px">'+b+'</span><span style="color:var(--pos);font-weight:700;font-size:16px">+</span></div>'}).join('')}

function sNotifs(){return [
{t:'Cap One Savings \u2014 47d stale',u:true},{t:'Shopping $35 over cap',u:true},{t:'Spending 38% faster',u:true},{t:'Duplicate: Whole Foods $67.43'},{t:'Auto-saved $20 to Emergency'},{t:'Caroline freelance expected today'},{t:'$147/mo bill savings found'},{t:'Electric bill due tomorrow'}
].map(function(n){return '<div class="tr" style="gap:8px"><div class="dot" style="width:6px;height:6px;background:'+(n.u?'var(--neg)':'var(--pos)')+';flex-shrink:0"></div><div style="flex:1;font-weight:'+(n.u?700:500)+';font-size:12px;color:'+(n.u?'var(--neg)':'var(--t1)')+'">'+n.t+'</div></div>'}).join('')}

function sExport(){return ['Current Month (CSV)','Year-to-Date (CSV)','Tax Summary (PDF)','Audit Trail (PDF)','Budget Report (PDF)','Net Worth History (CSV)'].map(function(o){return '<div class="ci" style="margin-bottom:4px;display:flex;align-items:center;gap:8px;cursor:pointer">'+ic(icons.download,14,'var(--acc)',1.5)+'<span style="flex:1;font-weight:600;font-size:12px">'+o+'</span></div>'}).join('')}


/* ========== THEME ========== */
var themeColors={emerald:'#1a5e3a',light:'#f2f2f7',dark:'#000000',midnight:'#0a0e1a',gold:'#12100b'};
function updateThemeColor(t){var m=document.querySelector('meta[name="theme-color"]');if(m)m.setAttribute('content',themeColors[t]||'#1a5e3a')}
function setTheme(t){
  /* Preserve unsaved alert toggle states before re-render */
  if(pg==='settings'){
    var e=$('togEmail'),s=$('togSMS');
    if(e)alertPrefs.email=e.classList.contains('on');
    if(s)alertPrefs.sms=s.classList.contains('on');
    Object.keys(alertPrefs.types).forEach(function(k){var el=$('togAlert_'+k);if(el)alertPrefs.types[k]=el.classList.contains('on')});
  }
  theme=t;try{localStorage.setItem('nw-theme',t)}catch(e){}document.body.setAttribute('data-theme',t);updateThemeColor(t);rr();
}
function saveAlertSettings(){
  var e=$('togEmail'),s=$('togSMS');
  if(e)alertPrefs.email=e.classList.contains('on');
  if(s)alertPrefs.sms=s.classList.contains('on');
  Object.keys(alertPrefs.types).forEach(function(k){var el=$('togAlert_'+k);if(el)alertPrefs.types[k]=el.classList.contains('on')});
  saveAlerts();os('Saved',sDone('Alert preferences saved successfully.\n\n'+(alertPrefs.email?'Email: ON \u2014 '+alertPrefs.emailAddr:'Email: OFF')+'\n'+(alertPrefs.sms?'SMS: ON':'SMS: OFF')));
}


