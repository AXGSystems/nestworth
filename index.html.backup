svgAreaChart(cashFlow,700,180,'var(--pos)','var(--neg)','Income','Expenses')+
'</div>'+

relatedPages([{label:'Home',tab:'home'},{label:'Accounts',pg:'accounts'},{label:'Transactions',pg:'transactions'},{label:'Subscriptions',pg:'subscriptions'},{label:'Fee Analyzer',pg:'feeanalyzer'},{label:'Sync Health',pg:'synchealth'}])+

'</div>';
}

/* ===== MOBILE TRACK (unchanged) ===== */
return '<div class="fi">'+
'<div class="hero" style="padding:18px"><div style="font-size:40px;font-weight:800;letter-spacing:-2.5px">$290k</div><div style="font-size:13px;opacity:0.85;margin-top:2px">across all accounts &middot; +8.2% this year</div><div style="margin-top:10px;display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:4px">'+[{l:'Investments',v:'$180.5k',cl:'#fff'},{l:'401(k)',v:'$68.4k',cl:'var(--gold)'},{l:'Real Estate',v:'$29.2k',cl:'var(--warn)'},{l:'Other',v:'$11.9k',cl:'rgba(255,255,255,0.5)'}].map(function(s){return '<div class="r" style="gap:4px"><div class="dot" style="width:6px;height:6px;background:'+s.cl+'"></div><span style="font-size:11px;font-weight:600;flex:1">'+s.l+'</span><span style="font-size:11px;font-weight:700">'+s.v+'</span></div>'}).join('')+'</div></div>'+

/* Accounts */
'<div class="c tap" onclick="gp(\'accounts\')"><div class="r" style="margin-bottom:10px">'+hd('Your Accounts')+'<span style="margin-left:auto;font-size:11px;font-weight:600;color:var(--acc)">View All</span></div>'+
'<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:6px">'+
[{l:'Chase Checking',a:'$5,360',s:'g'},{l:'Chase Savings',a:'$12,400',s:'g'},{l:'Capital One',a:'$2,100',s:'y'},{l:'Cap One Savings',a:'$8,200',s:'r'},{l:'Ally Invest',a:'$26,500',s:'g'},{l:'Credit Cards',a:'-$1,200',s:'g'}].map(function(x){return '<div class="ci" style="padding:8px 10px;position:relative"><div class="dot" style="position:absolute;top:6px;right:6px;width:6px;height:6px;background:'+(x.s==='g'?'var(--pos)':x.s==='y'?'var(--warn)':'var(--neg)')+'"></div><div style="font-size:10px;font-weight:600;color:var(--t2);margin-bottom:2px">'+x.l+'</div><div style="font-size:15px;font-weight:800;color:'+(x.s==='r'?'var(--neg)':'var(--t1)')+'">'+x.a+'</div>'+(x.s==='r'?'<div style="font-size:9px;font-weight:700;color:var(--neg)">47d stale</div>':'')+'</div>'}).join('')+'</div></div>'+

/* Transactions */
'<div class="c">'+hd('Recent Activity')+
[{w:'V',n:'Whole Foods',c:'Groceries',a:'-$67.43',t:'Today'},{w:'C',n:'TreatYoSelf',c:'Clothing',a:'-$650',t:'Yesterday',f:true},{w:'V',n:'Shell Gas',c:'Transport',a:'-$48.20',t:'Yesterday'},{w:'J',n:'Mortgage',c:'Housing',a:'-$2,000',t:'Friday',rc:true},{w:'C',n:'Target Refund',c:'Refund',a:'+$84.50',t:'Apr 10',rf:true},{w:'T',n:'Chase to Ally',c:'Transfer',a:'$500',t:'Apr 9',tr:true}].map(function(tx){return '<div class="tr" style="'+(tx.tr?'opacity:0.5':'')+'" onclick="os(\'Transaction\',sTx(\''+tx.n+'\',\''+tx.a+'\',\''+tx.c+'\',\''+tx.w+'\'))">'+av(tx.w,26,tx.w==='C'?'var(--warn)':tx.w==='J'?'var(--info)':tx.w==='T'?'var(--t2)':'var(--acc)')+'<div style="flex:1;min-width:0"><div class="r" style="gap:3px"><span style="font-weight:600;font-size:12px">'+tx.n+'</span>'+(tx.f?bg('FLAG','var(--neg)'):'')+(tx.rc?bg('Recurring','var(--info)'):'')+(tx.rf?bg('Refund','var(--pos)'):'')+(tx.tr?bg('Transfer','var(--t2)'):'')+'</div><div class="sub">'+tx.c+' &middot; '+tx.t+'</div></div><span style="font-weight:800;font-size:12px;color:'+(tx.rf?'var(--pos)':tx.f?'var(--neg)':tx.tr?'var(--t2)':'var(--t1)')+';flex-shrink:0">'+tx.a+'</span></div>'}).join('')+
'<div class="ci" style="margin-top:8px;display:flex;align-items:center;gap:8px;background:var(--warnBg);border:0.5px solid color-mix(in srgb,var(--warn) 12%,transparent);cursor:pointer" onclick="os(\'Duplicate Detected\',sDup())">'+ic(icons.warn,14,'var(--warn)',2.5)+'<div style="flex:1"><div style="font-weight:700;font-size:11px;color:var(--warn)">Possible duplicate</div><div class="sub">Whole Foods $67.43 appeared twice</div></div><button class="btn-pill" style="background:var(--warnBg);color:var(--warn)">Review</button></div></div>'+

/* Bills */
'<div class="c"><div class="r" style="margin-bottom:10px">'+hd('Bills Coming Up')+bg('3 this week','var(--warn)')+'</div>'+
'<div class="sub" style="margin-bottom:8px;margin-top:-6px">3 bills due this week &mdash; 2 on autopay</div>'+
[{n:'Electric Bill',a:145,d:'Tomorrow',at:false},{n:'Internet',a:89,d:'Apr 15',at:true},{n:'Car Payment',a:385,d:'Apr 15',at:true}].map(function(b){return '<div class="tr" onclick="os(\''+b.n+'\',sBill(\''+b.n+'\','+b.a+','+b.at+',\''+b.d+'\'))"><div style="width:30px;height:30px;border-radius:10px;background:'+(b.at?'var(--posBg)':'var(--warnBg)')+';display:flex;align-items:center;justify-content:center;flex-shrink:0">'+(b.at?ic(icons.check,12,'var(--pos)',3):ic(icons.warn,12,'var(--warn)',2.5))+'</div><div style="flex:1"><div class="r" style="gap:4px"><span style="font-weight:600;font-size:12px">'+b.n+'</span>'+(b.at?bg('Auto','var(--pos)'):bg('Manual','var(--warn)'))+'</div><div class="sub">Due '+b.d+'</div></div><span style="font-weight:800;font-size:13px;flex-shrink:0">$'+b.a+'</span></div>'}).join('')+'</div>'+

/* Receipt Scanner */
'<div class="c tap" onclick="gp(\'scanner\')"><div class="r">'+ic(icons.cam,16,'var(--acc)',1.5)+'<div style="flex:1"><div style="font-weight:700;font-size:12px">Receipt Scanner</div><div class="sub">Snap, match, attach to any transaction</div></div>'+bg('NEW','var(--gold)')+'</div>'+pendingBadge('Capacitor/native camera')+'</div>'+

renderAd('partner')+

'</div>'}


/* ========== COACH PAGE ========== */
function rCoach(){
if(isDesktop()){
/* ===== DESKTOP COACH — 70/30 split ===== */
return '<div class="fi"><div class="dash-coach-row">'+

/* LEFT: Chat area (70%) */
'<div class="dash-coach-main">'+
'<div class="chart-container" style="flex:1;display:flex;flex-direction:column;margin-bottom:0">'+
'<div class="r" style="gap:8px;margin-bottom:10px;padding-bottom:10px;border-bottom:0.5px solid var(--sep)"><div style="width:32px;height:32px;border-radius:16px;background:var(--acc);display:flex;align-items:center;justify-content:center;flex-shrink:0">'+ic(icons.lightbulb,14,'#fff',2)+'</div><div style="flex:1"><div style="font-weight:700;font-size:14px">NestWorth Intelligence</div><div class="sub">Your household AI &mdash; always watching, never judging</div></div>'+pendingBadge('LLM API integration')+'<div style="display:flex;gap:3px">'+av('V',22)+av('C',22,'var(--warn)')+'</div></div>'+
'<div id="cmsgs" style="flex:1;overflow-y:auto;padding:8px 0;min-height:400px">'+
'<div class="msg-in" style="max-width:70%">Good morning, Von. Here\'s your household pulse for April 15:<br><br>&bull; <strong>Net worth</strong>: $82,450 &mdash; up $1,250 this month<br>&bull; <strong>Health score</strong>: 74/100 &mdash; getting stronger<br>&bull; <strong>Heads up</strong>: Cap One Savings hasn\'t synced in 47 days<br>&bull; <strong>Shopping</strong> is $35 over cap &mdash; both partners notified<br>&bull; <strong>Velocity</strong>: spending 38% faster than usual<br>&bull; Von\'s ALTA paycheck lands Apr 25 &mdash; on track<br>&bull; I found <strong>$147/mo in bill savings</strong> worth claiming<br>&bull; Possible duplicate: Whole Foods $67.43<br>&bull; Emergency fund covers 0.8 months &mdash; 28% to goal<br><br>What would you like to explore?</div></div>'+
'<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px">'+['Spending','Sync','Bills','Save','Audit','Forecast','Net Worth','Tax Deductions'].map(function(q){return '<button class="btn-pill" onclick="sC(\''+q+'\')">'+q+'</button>'}).join('')+'</div>'+
'<div class="r" style="gap:8px"><input id="ci" maxlength="500" placeholder="Ask about your household finances..." style="flex:1;min-width:0;padding:14px 20px;border-radius:20px;font-size:14px;border:0.5px solid var(--cardBorder);background:var(--cardBg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);outline:none;color:var(--t1)" onkeydown="if(event.key===\'Enter\')sC()"><button onclick="sC()" aria-label="Send message" style="width:48px;height:48px;border-radius:24px;background:var(--acc);color:#fff;font-size:20px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shM);flex-shrink:0;transition:transform var(--fast) var(--spring)" onmousedown="this.style.transform=\'scale(0.9)\'" onmouseup="this.style.transform=\'\'">&#x2191;</button></div>'+
'</div></div>'+

/* RIGHT: Quick stats panel (30%) */
'<div class="dash-coach-side">'+

/* Quick Stats */
'<div class="chart-container" style="margin-bottom:0"><div class="chart-title">Your Numbers Today</div>'+
'<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">'+
[{l:'Net Worth',v:'$82.4k',c:'var(--t1)'},{l:'Health',v:'74',c:'var(--acc)'},{l:'Savings Rate',v:'39%',c:'var(--pos)'},{l:'Debt',v:'$3.2k',c:'var(--neg)'}].map(function(s){return '<div class="ci" style="text-align:center;padding:8px"><div class="sub" style="font-size:9px">'+s.l+'</div><div style="font-size:16px;font-weight:800;color:'+s.c+'">'+s.v+'</div></div>'}).join('')+
'</div>'+
'<div style="margin-top:8px">'+svgSparkline(nwHistory.map(function(d){return d.v}),300,24,'var(--acc)')+'</div>'+
'</div>'+

/* Recent Insights */
'<div class="chart-container" style="margin-bottom:0"><div class="chart-title">What I\'m Watching</div>'+
[{t:'Bill audit found $147/mo savings',c:'var(--pos)'},{t:'Spending 38% faster than average',c:'var(--neg)'},{t:'Cap One Savings stale 47 days',c:'var(--warn)'},{t:'Emergency fund at 0.8 months',c:'var(--warn)'},{t:'Duplicate: Whole Foods $67.43',c:'var(--neg)'}].map(function(ins){return '<div class="r" style="padding:5px 0;border-bottom:0.5px solid var(--sep);gap:6px"><div style="width:4px;height:4px;border-radius:2px;background:'+ins.c+';flex-shrink:0;margin-top:5px"></div><div style="font-size:11px;font-weight:500;color:var(--t1);flex:1">'+ins.t+'</div></div>'}).join('')+
'</div>'+

/* Suggested Actions */
'<div class="chart-container" style="margin-bottom:0"><div class="chart-title">Recommended Next Steps</div>'+
[{a:'Reconnect Cap One Savings',p:'High',c:'var(--neg)',pg:'synchealth'},{a:'Review TreatYoSelf $650 flag',p:'Med',c:'var(--warn)',pg:'transactions'},{a:'Set up autopay for Electric',p:'Med',c:'var(--warn)',pg:'billscalendar'},{a:'Increase emergency fund save',p:'Low',c:'var(--acc)',pg:'emergencyfund'}].map(function(act){return '<div class="ci" style="margin-bottom:4px;cursor:pointer;display:flex;align-items:center;gap:6px" onclick="gp(\''+act.pg+'\')"><div style="flex:1"><div style="font-size:11px;font-weight:600">'+act.a+'</div></div>'+bg(act.p,act.c)+'</div>'}).join('')+
'</div>'+

'</div>'+/* end coach-side */
'</div></div>';/* end coach-row and fi */
}

/* ===== MOBILE COACH (unchanged) ===== */
return '<div class="fi" style="display:flex;flex-direction:column;min-height:calc(100vh - 180px);min-height:calc(100dvh - 180px)">'+
'<div class="ci" style="display:flex;align-items:center;gap:8px;margin-bottom:10px;background:var(--accS);border-color:color-mix(in srgb,var(--acc) 12%,transparent)"><div style="width:30px;height:30px;border-radius:15px;background:var(--acc);display:flex;align-items:center;justify-content:center;flex-shrink:0">'+ic(icons.lightbulb,14,'#fff',2)+'</div><div style="flex:1"><div style="font-weight:700;font-size:12px">NestWorth Intelligence</div><div class="sub">Always watching, never judging</div></div><div style="display:flex;gap:2px">'+av('V',18)+av('C',18,'var(--warn)')+'</div></div>'+
pendingBadge('LLM API integration')+
'<div id="cmsgs" style="flex:1;overflow-y:auto;padding:8px 0"><div class="msg-in">Morning, Von. Quick pulse:<br><br>&bull; Net worth: <strong>$82,450</strong> (+$1,250)<br>&bull; Health: 74/100 &mdash; improving<br>&bull; Cap One Savings &mdash; 47d stale<br>&bull; Shopping $35 over cap<br>&bull; Spending 38% faster than normal<br>&bull; Found <strong>$147/mo in savings</strong><br>&bull; 1 duplicate to review<br>&bull; Emergency fund: 28% to goal<br><br>What should we dig into?</div></div>'+
'<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px">'+['Spending','Sync','Bills','Save','Audit','Forecast'].map(function(q){return '<button class="btn-pill" onclick="sC(\''+q+'\')">'+q+'</button>'}).join('')+'</div>'+
'<div class="r" style="gap:6px"><input id="ci" maxlength="500" placeholder="Ask about your household..." style="flex:1;min-width:0;padding:12px 16px;border-radius:20px;font-size:13px;border:0.5px solid var(--cardBorder);background:var(--cardBg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);outline:none;color:var(--t1)" onkeydown="if(event.key===\'Enter\')sC()"><button onclick="sC()" aria-label="Send message" style="width:44px;height:44px;border-radius:22px;background:var(--acc);color:#fff;font-size:18px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shM);flex-shrink:0;transition:transform var(--fast) var(--spring)" onmousedown="this.style.transform=\'scale(0.9)\'" onmouseup="this.style.transform=\'\'">&#x2191;</button></div>'+
'</div>'}

var CA={Spending:"This week:\n\n\u25cf Von: $145\n\u25cf Caroline: $755 (TreatYoSelf $650)\n\nSpending 38% faster than average. May exceed budget by $420.",Sync:"Cap One Savings disconnected by Caroline Mar 12. 47 days stale. Cross-reference shows 3 unmatched ($342).\n\nMonarch shows stale numbers silently. We flag it.",Bills:"4 savings opportunities:\n1. Insurance: -$38\n2. Streaming: -$24\n3. Internet: -$25\n4. Phone: -$60\n\n+3 unused subs: $62\nTotal: $209/mo \u2192 $2,508/yr",Save:"7 moves for $409/mo ($4,908/yr):\n1. Bill audit $147\n2. Drop subs $62\n3. Tighten Shopping\n4. Tighten Dining\n5. Round-Ups for Caroline\n6. Bump daily save\n7. Switch phone",Audit:"Mar 12 \u2014 Caroline disconnected Cap One\nMar 10 \u2014 Caroline deleted Target $84.50\nMar 14 \u2014 Von reconnected\nFeb 25 \u2014 Recategorized Amazon\nFeb 20 \u2014 Von exported Q1",Forecast:"At current pace:\n\u2022 End of April: $84,800\n\u2022 End of Q2: $89,200\n\u2022 End of Year: $115,400\n\nWith bill audit savings applied:\n\u2022 End of Year: $117,200 (+$1,764)"};
function sC(t){var i=$('ci');var m=t||i.value.trim();if(!m)return;i.value='';var c=$('cmsgs');c.innerHTML+='<div class="msg-out">'+esc(m)+'</div>';setTimeout(function(){c.innerHTML+='<div class="msg-in">'+(CA[m]||'Net worth grew $320 today. Monitoring all accounts for gaps and anomalies.').replace(/\n/g,'<br>')+'</div>';c.scrollTop=c.scrollHeight},600)}


/* ========== INTERACTIVE HELPERS ========== */
function toggleChip(el){
  var siblings=el.parentElement.querySelectorAll('.filter-chip');
  siblings.forEach(function(s){s.classList.remove('active')});
  el.classList.add('active');
}
function toggleDateBtn(el){
  var siblings=el.parentElement.querySelectorAll('button');
  siblings.forEach(function(s){s.classList.remove('active')});
  el.classList.add('active');
}
function toggleHeroRange(el){
  var siblings=el.parentElement.querySelectorAll('button');
  siblings.forEach(function(s){s.style.color='rgba(255,255,255,0.5)';s.style.background='transparent'});
  el.style.color='rgba(255,255,255,1)';el.style.background='rgba(255,255,255,0.15)';
}

