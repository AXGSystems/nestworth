cats.map(function(c){var p=Math.round((c.s/c.a)*100);return '<div style="margin-bottom:12px;cursor:pointer" onclick="os(\''+c.n+'\',sCat(\''+c.n+'\','+c.s+','+c.a+','+Math.round(c.s*0.45)+','+Math.round(c.s*0.55)+'))"><div class="r" style="margin-bottom:3px;gap:4px"><span style="font-size:12px;font-weight:600;flex:1">'+c.n+'</span>'+(c.o?bg('OVER','var(--neg)'):'')+(c.w?bg(p+'%','var(--warn)'):'')+'<span style="font-size:12px;font-weight:800;color:'+(c.o?'var(--neg)':'var(--t1)')+'">$'+c.s+'<span style="font-weight:400;color:var(--t3);font-size:10px">/$'+c.a+'</span></span></div>'+br(p,c.o?'var(--neg)':p>80?'var(--warn)':'var(--pos)')+'<div style="display:flex;gap:8px;margin-top:3px;font-size:9px;color:var(--t2)"><span style="color:var(--acc)">Von $'+Math.round(c.s*0.45)+'</span><span style="color:var(--warn)">Caroline $'+Math.round(c.s*0.55)+'</span></div></div>'}).join('')+'</div>'+

