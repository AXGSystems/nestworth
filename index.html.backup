  {value:68400,color:'var(--gold)',label:'401(k)'},
  {value:29200,color:'var(--warn)',label:'Real Estate'},
  {value:11900,color:'var(--t2)',label:'Other'}
];
var accounts=[{l:'Chase Checking',a:'$5,360',v:5360,s:'g',t:'2h ago',who:'Joint'},{l:'Chase Savings',a:'$12,400',v:12400,s:'g',t:'2h ago',who:'Joint'},{l:'Capital One',a:'$2,100',v:2100,s:'y',t:'3d ago',who:'Von'},{l:'Cap One Savings',a:'$8,200',v:8200,s:'r',t:'47d ago',who:'Caroline'},{l:'Ally Invest',a:'$26,500',v:26500,s:'g',t:'1d ago',who:'Von'},{l:'Credit Cards',a:'-$1,200',v:-1200,s:'g',t:'6h ago',who:'Joint'}];
return '<div class="fi">'+

/* Hero with allocation donut */
'<div class="hero dash-full" style="padding:24px 28px 20px">'+
'<div style="display:flex;justify-content:space-between;align-items:flex-start">'+
'<div><div style="font-size:13px;opacity:0.85">Your Accounts at a Glance</div>'+
'<div style="font-size:48px;font-weight:800;letter-spacing:-3px;margin-top:4px">$290,000</div>'+
'<div style="margin-top:8px;display:flex;gap:20px">'+
[{l:'Investments',v:'$180.5k'},{l:'401(k)',v:'$68.4k'},{l:'Real Estate',v:'$29.2k'},{l:'Other',v:'$11.9k'}].map(function(s){return '<div><span style="opacity:0.6;font-size:11px">'+s.l+'</span> <span style="font-size:15px;font-weight:800">'+s.v+'</span></div>'}).join('')+
'</div></div>'+
'<div style="display:grid;grid-template-columns:repeat(3,auto);gap:16px;text-align:right;margin-top:4px">'+
'<div><div style="font-size:10px;opacity:0.6">YTD Return</div><div style="font-size:16px;font-weight:800;color:rgba(255,255,255,0.9)">+8.2%</div></div>'+
'<div><div style="font-size:10px;opacity:0.6">Expense Ratio</div><div style="font-size:16px;font-weight:800">0.42%</div></div>'+
'<div><div style="font-size:10px;opacity:0.6">Fee Drag (30yr)</div><div style="font-size:16px;font-weight:800;color:rgba(255,255,255,0.7)">$47k</div></div>'+
'</div></div></div>'+

/* Two column */
'<div class="dash-row">'+

/* LEFT */
'<div class="dash-main">'+

/* Full Accounts Table */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Your Accounts</span><span class="view-all" onclick="gp(\'accounts\')">Manage &rarr;</span></div>'+
'<div class="sub" style="margin-bottom:8px">6 accounts linked &middot; 4 syncing healthy &middot; 1 needs attention</div>'+
'<table class="data-table"><thead><tr><th>Account</th><th>Owner</th><th>Last Sync</th><th>Status</th><th style="text-align:right">Balance</th></tr></thead><tbody>'+
accounts.map(function(x){return '<tr style="cursor:pointer" onclick="gp(\'accounts\')"><td style="font-weight:600">'+x.l+'</td><td style="color:var(--t2)">'+x.who+'</td><td style="color:var(--t2)">'+x.t+'</td><td>'+(x.s==='g'?bg('Synced','var(--pos)'):x.s==='y'?bg('Slow','var(--warn)'):bg('Stale','var(--neg)'))+'</td><td class="amount" style="color:'+(x.v<0?'var(--neg)':'var(--t1)')+'">'+x.a+'</td></tr>'}).join('')+
'</tbody></table></div>'+

/* Transaction Search & Filter (Mint feature) */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Recent Transactions</span><span class="view-all" onclick="gp(\'transactions\')">View All &rarr;</span></div>'+
'<div class="sub" style="margin-bottom:8px">9 transactions this week &middot; 1 flagged &middot; 1 possible duplicate</div>'+
'<div class="filter-bar"><input class="filter-input" placeholder="Search transactions..." onkeydown="event.stopPropagation()">'+
['All','This Month','Last Month','Last 3 Mo','YTD'].map(function(f,i){return '<button class="filter-chip'+(i===1?' active':'')+'" onclick="toggleChip(this)">'+f+'</button>'}).join('')+
'</div>'+
'<div class="filter-bar" style="margin-bottom:8px">'+
['All Categories','Groceries','Dining','Shopping','Transport','Housing'].map(function(f,i){return '<button class="filter-chip'+(i===0?' active':'')+'" onclick="toggleChip(this)">'+f+'</button>'}).join('')+
'</div>'+
'<table class="data-table"><thead><tr><th>Who</th><th>Merchant</th><th>Category</th><th>Date</th><th>Tags</th><th style="text-align:right">Amount</th></tr></thead><tbody>'+
[{w:'V',n:'Whole Foods',c:'Groceries',a:'-$67.43',t:'Today'},
{w:'C',n:'TreatYoSelf',c:'Clothing',a:'-$650',t:'Yesterday',f:true},
{w:'V',n:'Shell Gas',c:'Transport',a:'-$48.20',t:'Yesterday'},
{w:'J',n:'Mortgage',c:'Housing',a:'-$2,000',t:'Friday',rc:true},
{w:'C',n:'Target Refund',c:'Refund',a:'+$84.50',t:'Apr 10',rf:true},
{w:'T',n:'Chase to Ally',c:'Transfer',a:'$500',t:'Apr 9',tr:true},
{w:'V',n:'Netflix',c:'Subs',a:'-$15.49',t:'Apr 10'},
{w:'C',n:'Amazon',c:'Shopping',a:'-$150',t:'Apr 10'},
{w:'V',n:'ALTA Payroll',c:'Income',a:'+$4,280',t:'Apr 11',inc:true}
].map(function(tx){return '<tr style="cursor:pointer;'+(tx.tr?'opacity:0.5':'')+'" onclick="os(\'Transaction\',sTx(\''+tx.n+'\',\''+tx.a+'\',\''+tx.c+'\',\''+tx.w+'\'))"><td>'+av(tx.w,22,tx.w==='C'?'var(--warn)':tx.w==='J'?'var(--info)':tx.w==='T'?'var(--t2)':'var(--acc)')+'</td><td style="font-weight:600">'+tx.n+'</td><td style="color:var(--t2)">'+tx.c+'</td><td style="color:var(--t2)">'+tx.t+'</td><td>'+(tx.f?bg('FLAG','var(--neg)'):'')+(tx.rc?bg('Recurring','var(--info)'):'')+(tx.rf?bg('Refund','var(--pos)'):'')+(tx.tr?bg('Transfer','var(--t2)'):'')+(tx.inc?bg('INCOME','var(--pos)'):'')+'</td><td class="amount" style="color:'+(tx.inc||tx.rf?'var(--pos)':tx.f?'var(--neg)':tx.tr?'var(--t2)':'var(--t1)')+'">'+tx.a+'</td></tr>'}).join('')+
'</tbody></table>'+
'<div class="ci" style="margin-top:8px;display:flex;align-items:center;gap:8px;background:var(--warnBg);border:0.5px solid color-mix(in srgb,var(--warn) 12%,transparent);cursor:pointer" onclick="os(\'Duplicate Detected\',sDup())">'+ic(icons.warn,14,'var(--warn)',2.5)+'<div style="flex:1"><div style="font-weight:700;font-size:11px;color:var(--warn)">Possible duplicate</div><div class="sub">Whole Foods $67.43 appeared twice</div></div><button class="btn-pill" style="background:var(--warnBg);color:var(--warn)">Review</button></div>'+
'</div>'+

/* Receipt Scanner */
'<div class="c tap" onclick="gp(\'scanner\')"><div class="r">'+ic(icons.cam,16,'var(--acc)',1.5)+'<div style="flex:1"><div style="font-weight:700;font-size:12px">Receipt Scanner</div><div class="sub">Snap, match, attach to any transaction</div></div>'+bg('NEW','var(--gold)')+'</div>'+pendingBadge('Capacitor/native camera')+'</div>'+

'</div>'+/* end dash-main */

/* RIGHT */
