'<div><span class="sub">Paid</span> <span style="font-weight:700;font-size:13px;color:var(--pos)">$2,184</span></div></div>'+
'<div class="sub" style="margin-top:4px">$1,194 remaining &middot; 7 of 9 on autopay</div>'+
'</div>'+

/* Subscription Audit */
'<div class="chart-container dash-section" style="cursor:pointer" onclick="gp(\'subscriptions\')"><div class="dash-section-header"><span class="chart-title" style="margin-bottom:0">Subscription Pulse</span>'+bg('3 issues','var(--neg)')+'</div>'+
'<div style="margin-bottom:6px"><span class="sub">12 active &middot; 3 barely used</span> <span style="font-weight:700">$287/mo</span></div>'+
[{n:'Netflix',a:'$15.49',ok:true},{n:'Hulu',a:'$17.99',i:'Low use'},{n:'Disney+',a:'$13.99',i:'<5%'},{n:'Headspace',a:'$14.99',i:'60d idle'}].map(function(s){return '<div class="r" style="padding:4px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:11px;font-weight:600;flex:1">'+s.n+'</span>'+(s.i?bg(s.i,'var(--neg)'):bg('OK','var(--pos)'))+'<span style="font-size:11px;font-weight:700;width:48px;text-align:right">'+s.a+'</span></div>'}).join('')+
'</div>'+

/* Fee Analyzer */
'<div class="chart-container dash-section" style="cursor:pointer" onclick="gp(\'feeanalyzer\')"><div class="chart-title">Hidden Fee Impact</div>'+
