var incomeHistory=[{m:'May',v:7800},{m:'Jun',v:8100},{m:'Jul',v:7400},{m:'Aug',v:8280},{m:'Sep',v:7080},{m:'Oct',v:8560},{m:'Nov',v:7080},{m:'Dec',v:7080},{m:'Jan',v:7280},{m:'Feb',v:7080},{m:'Mar',v:7280},{m:'Apr',v:7080}];
var mobileContent=incomeSources.map(function(p){return '<div class="ci" style="margin-bottom:4px;'+(p.st==='due'?'border-color:color-mix(in srgb,var(--warn) 15%,transparent);background:var(--warnBg)':'')+';padding:8px 10px"><div class="r" style="margin-bottom:1px"><span style="font-weight:600;font-size:11px;flex:1">'+p.s+'</span><span style="font-weight:800;font-size:11px;color:var(--pos);flex-shrink:0">'+p.a+'</span></div><div class="r" style="gap:4px"><div class="dot" style="width:5px;height:5px;background:'+(p.st==='ok'?'var(--pos)':'var(--warn)')+'"></div><span style="font-size:9px;color:'+(p.st==='ok'?'var(--pos)':'var(--warn)')+'">'+(p.st==='ok'?'On Track':'Expected Today')+'</span><span class="sub" style="margin-left:auto;font-size:9px">'+p.f+' &middot; Next: '+p.n+'</span></div></div>'}).join('');

if(isDesktop()){
var smoothedData=[{m:'May',v:7600},{m:'Jun',v:7650},{m:'Jul',v:7640},{m:'Aug',v:7720},{m:'Sep',v:7700},{m:'Oct',v:7780},{m:'Nov',v:7750},{m:'Dec',v:7750},{m:'Jan',v:7760},{m:'Feb',v:7750},{m:'Mar',v:7760},{m:'Apr',v:7760}];
return '<div class="fi">'+
'<div class="stat-row cols-4">'+
'<div class="stat-card"><div class="stat-label">Monthly Income</div><div class="stat-value" style="color:var(--pos)">$7,080</div>'+trendIndicator(7080,7280,'','')+'</div>'+
'<div class="stat-card"><div class="stat-label">Sources</div><div class="stat-value">3</div></div>'+
'<div class="stat-card"><div class="stat-label">12mo Average</div><div class="stat-value">$7,590</div></div>'+
'<div class="stat-card"><div class="stat-label">Variance</div><div class="stat-value" style="color:var(--warn)">12%</div></div>'+
'</div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container"><div class="chart-title">Income Sources</div>'+
'<table class="data-table"><thead><tr><th>Source</th><th>Person</th><th>Frequency</th><th>Next Expected</th><th>Status</th><th style="text-align:right">Amount</th></tr></thead><tbody>'+
incomeSources.map(function(p){return '<tr><td style="font-weight:700">'+p.s+'</td><td>'+(p.s.indexOf('Von')>=0?av('V',20)+'Von':p.s.indexOf('Caroline')>=0?av('C',20,'var(--warn)')+'Caroline':'Joint')+'</td><td>'+p.f+'</td><td>'+p.n+'</td><td>'+bg(p.st==='ok'?'On Track':'Expected',p.st==='ok'?'var(--pos)':'var(--warn)')+'</td><td class="amount" style="color:var(--pos)">'+p.a+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container"><div class="chart-title">Income Trend (12 Months)</div><div class="chart-subtitle">Actual income per month</div>'+
svgLineChart(incomeHistory,500,180,'var(--pos)','Income')+'</div>'+
'<div class="chart-container"><div class="chart-title">Income Smoothing</div><div class="chart-subtitle">Actual (green) vs Smoothed Target (blue) - reduces feast/famine cycles</div>'+
svgLineChart(incomeHistory,500,140,'var(--pos)','Actual')+
'<div style="margin-top:8px">'+svgLineChart(smoothedData,500,140,'var(--acc)','Smoothed Target')+'</div>'+
'<div class="ci" style="margin-top:8px;background:var(--accS)"><div style="font-weight:700;font-size:11px">Income Smoothing Buffer</div><div class="sub" style="line-height:1.5">Recommended buffer: $2,400. When income exceeds $7,760/mo, excess goes to buffer. When below, buffer covers the gap. Current buffer: $1,200.</div></div></div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Income by Source</div>'+
svgDonut([{label:'ALTA Payroll',value:4280,color:'var(--acc)'},{label:'Freelance',value:2800,color:'var(--warn)'},{label:'Rental',value:1200,color:'var(--pos)'}],160,'$8.3k','Monthly')+'</div>'+
'<div class="chart-container"><div class="chart-title">Payment Calendar</div><div class="chart-subtitle">April 2026</div>'+
buildBillsCalendarSVG()+
'<div style="margin-top:8px;font-size:10px;color:var(--t2)"><div class="dot" style="width:6px;height:6px;background:var(--pos);display:inline-block"></div> Income days marked</div></div>'+
'<div class="chart-container"><div class="chart-title">Next Expected Payments</div>'+
[{d:'Apr 15',s:'Freelance (Caroline)',a:'~$2,800',st:'due'},{d:'Apr 25',s:'ALTA Payroll',a:'$4,280',st:'ok'},{d:'May 1',s:'Rental Income',a:'$1,200',st:'ok'}].map(function(np){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span style="font-size:10px;font-weight:700;width:48px;color:'+(np.st==='due'?'var(--warn)':'var(--t2)')+'">'+np.d+'</span><span style="font-size:11px;flex:1;font-weight:600">'+np.s+'</span><span style="font-size:11px;font-weight:800;color:var(--pos)">'+np.a+'</span></div>'}).join('')+'</div>'+
'</div></div></div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs">'+hd('Income','Cadence')+mobileContent+'</div></div>'}

