'<table class="data-table"><thead><tr><th>Expense</th><th>Paid By</th><th>Split</th><th style="text-align:right">Amount</th><th>Status</th></tr></thead><tbody>'+
[{n:'Groceries',w:'Von',split:'50/50',a:'$134.86',s:'Settled'},{n:'Electric Bill',w:'Caroline',split:'50/50',a:'$145.00',s:'Pending'},{n:'Dinner Out',w:'Von',split:'60/40',a:'$89.00',s:'Settled'},{n:'Gas',w:'Caroline',split:'50/50',a:'$48.20',s:'Pending'},{n:'Netflix',w:'Joint',split:'Auto',a:'$15.49',s:'Auto'}].map(function(e){return '<tr><td style="font-weight:600">'+e.n+'</td><td>'+e.w+'</td><td>'+bg(e.split,'var(--info)')+'</td><td class="amount">'+e.a+'</td><td>'+bg(e.s,e.s==='Settled'?'var(--pos)':e.s==='Pending'?'var(--warn)':'var(--acc)')+'</td></tr>'}).join('')+
