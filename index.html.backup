accounts.map(function(a){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep)"><div class="dot" style="width:6px;height:6px;background:'+(a.s==='ok'?'var(--pos)':a.s==='warn'?'var(--warn)':'var(--neg)')+'"></div><span style="font-size:11px;flex:1;font-weight:600">'+a.n+'</span>'+bg(a.s==='ok'?'Healthy':a.s==='warn'?'Warning':'Stale',a.s==='ok'?'var(--pos)':a.s==='warn'?'var(--warn)':'var(--neg)')+'</div>'}).join('')+'</div>'+
