nests.map(function(n){var p=Math.round((n.c/n.g)*100);var ne=n.n.replace(/'/g,"&#39;");
return '<tr style="cursor:pointer" onclick="os(\''+ne+'\',sNest(\''+ne+'\','+n.c+','+n.g+'))"><td style="font-weight:600">'+n.n+(n.p?' '+bg('Personal','var(--warn)'):'')+'</td><td style="color:var(--t2)">'+n.f+'</td><td style="color:var(--t2)">'+n.d+'</td><td class="amount" style="color:var(--acc)">$'+n.c.toLocaleString()+'</td><td class="amount" style="color:var(--t2)">$'+n.g.toLocaleString()+'</td><td>'+br(p,'var(--acc)',5)+'<div style="font-size:9px;font-weight:700;color:var(--acc);text-align:right;margin-top:1px">'+p+'%</div></td></tr>'}).join('')+
