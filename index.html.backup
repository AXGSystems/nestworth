'<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px">'+
[{l:'7yr',v:'$5.4k'},{l:'15yr',v:'$18.2k'},{l:'30yr',v:'$47k'}].map(function(p){return '<div class="ci" style="text-align:center;padding:6px"><div class="sub" style="font-size:8px">'+p.l+' drag</div><div style="font-size:12px;font-weight:800;color:var(--neg)">'+p.v+'</div></div>'}).join('')+
'</div></div>'+

/* Tax Deductions */
