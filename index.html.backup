['Send a Receipt','Request Split','Schedule Money Date','Share Goal Update'].map(function(a){return '<button class="btn-pill btn-full" style="margin-bottom:4px">'+a+'</button>'}).join('')+'</div>'+
'</div></div></div>';
}
