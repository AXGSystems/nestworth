[{n:'Electric Bill',a:'$72.50',d:'Apr 14',from:'Caroline'},{n:'Gas Station',a:'$24.10',d:'Yesterday',from:'Caroline'}].map(function(s){return '<div class="ci" style="margin-bottom:6px;border-color:color-mix(in srgb,var(--warn) 15%,transparent);background:var(--warnBg)"><div class="r"><span style="font-weight:700;font-size:12px;flex:1">'+s.n+'</span><span style="font-weight:800;font-size:12px;color:var(--warn)">'+s.a+'</span></div><div class="r" style="margin-top:4px"><span class="sub">'+s.from+' paid &middot; '+s.d+'</span><button class="btn-pill" style="font-size:10px;margin-left:auto">Settle</button></div></div>'}).join('')+'</div>'+
