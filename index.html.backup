'<table class="data-table"><thead><tr><th></th><th>Alert</th><th>Category</th><th>Timestamp</th><th>Status</th></tr></thead><tbody>'+
alertLog.map(function(al){var typeColors={overspend:'var(--neg)',velocity:'var(--warn)',sync:'var(--info)',bills:'var(--acc)',goals:'var(--pos)',anomaly:'var(--neg)',weekly:'var(--t2)'};return '<tr><td><div style="width:8px;height:8px;border-radius:4px;background:'+(al.read?'var(--pos)':'var(--neg)')+'"></div></td><td style="font-weight:'+(al.read?500:700)+';color:'+(al.read?'var(--t1)':'var(--neg)')+'">'+al.t+'</td><td>'+bg(al.type,typeColors[al.type]||'var(--info)')+'</td><td style="font-size:11px;color:var(--t2)">'+al.ts+'</td><td>'+(al.read?bg('Read','var(--pos)'):bg('New','var(--neg)'))+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Alert Preferences</div>'+
'<div class="r" style="padding:10px 0;border-bottom:0.5px solid var(--sep)"><div style="flex:1;display:flex;align-items:center;gap:8px">'+ic(icons.mail,16,'var(--acc)',1.5)+'<div><div style="font-weight:600;font-size:12px">Email Alerts</div><div class="sub">'+alertPrefs.emailAddr+'</div></div></div>'+tg(alertPrefs.email,false,'togEmail')+'</div>'+
'<div class="r" style="padding:10px 0;border-bottom:0.5px solid var(--sep)"><div style="flex:1;display:flex;align-items:center;gap:8px">'+ic(icons.phone,16,'var(--acc)',1.5)+'<div><div style="font-weight:600;font-size:12px">SMS Alerts</div><div class="sub">'+(alertPrefs.phone||'Add phone number')+'</div></div></div>'+tg(alertPrefs.sms,false,'togSMS')+'</div>'+
'<div style="margin-top:12px"><div style="font-weight:700;font-size:12px;margin-bottom:8px">Alert Types</div>'+
'<table class="data-table"><thead><tr><th>Alert Type</th><th>Description</th><th>Status</th><th>Toggle</th></tr></thead><tbody>'+
[['overspend','Category Overspend','Triggers when a category exceeds budget'],['sync','Account Sync Issues','Alerts on stale or failed syncs'],['bills','Bill Due Reminders','Notifies 3 days before bill due dates'],['goals','Goal Milestones','Celebrates when you hit savings milestones'],['anomaly','Anomaly Detection','Flags unusual charges or duplicates'],['velocity','Spending Velocity','Warns when spending pace is elevated'],['weekly','Weekly Summary','Sunday digest of the past week']].map(function(kv){return '<tr><td style="font-weight:600">'+kv[1]+'</td><td class="sub" style="font-size:11px">'+kv[2]+'</td><td>'+(alertPrefs.types[kv[0]]?bg('Active','var(--pos)'):bg('Off','var(--t3)'))+'</td><td>'+tg(alertPrefs.types[kv[0]],false,'togAlert_'+kv[0])+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<button class="btn btn-full" style="margin-top:12px;border-radius:22px;height:44px;font-size:13px" onclick="saveAlertSettings()">Save Alert Preferences</button>'+
pendingBadge('Email/SMS delivery backend')+'</div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Alert Volume (Last 4 Weeks)</div><div class="chart-subtitle">Alerts triggered per week by category</div>'+
svgBarChart([{label:'W1',value:12,color:'var(--acc)'},{label:'W2',value:8,color:'var(--acc)'},{label:'W3',value:15,color:'var(--warn)'},{label:'W4',value:10,color:'var(--acc)'}],500,140)+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Alert Distribution</div>'+
svgDonut([{label:'Overspend',value:4,color:'var(--neg)'},{label:'Sync',value:3,color:'var(--info)'},{label:'Bills',value:2,color:'var(--acc)'},{label:'Goals',value:2,color:'var(--pos)'},{label:'Anomaly',value:1,color:'var(--warn)'},{label:'Velocity',value:1,color:'var(--gold)'}],140,'13','this week')+'</div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Delivery Status</div>'+
'<div class="ci" style="margin-bottom:6px"><div class="r"><span style="font-size:12px;font-weight:700;flex:1">Email</span>'+bg(alertPrefs.email?'Active':'Off',alertPrefs.email?'var(--pos)':'var(--t3)')+'</div><div class="sub" style="margin-top:2px">'+alertPrefs.emailAddr+'</div></div>'+
'<div class="ci" style="margin-bottom:6px"><div class="r"><span style="font-size:12px;font-weight:700;flex:1">SMS</span>'+bg(alertPrefs.sms?'Active':'Off',alertPrefs.sms?'var(--pos)':'var(--t3)')+'</div><div class="sub" style="margin-top:2px">'+(alertPrefs.phone||'Not configured')+'</div></div>'+
'<div class="ci"><div class="r"><span style="font-size:12px;font-weight:700;flex:1">Push</span>'+bg('Not Configured','var(--warn)')+'</div><div class="sub" style="margin-top:2px">Requires native app</div></div></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Notification Frequency</div>'+
'<div class="sub" style="margin-bottom:8px">How often to send summaries</div>'+
['Real-time','Daily Digest','Weekly Summary'].map(function(f,i){return '<div class="ci" style="margin-bottom:4px;cursor:pointer;'+(i===0?'border-color:color-mix(in srgb,var(--acc) 20%,transparent);background:var(--accS)':'')+'"><div class="r"><span style="font-size:12px;font-weight:600;flex:1">'+f+'</span>'+(i===0?ic(icons.check,14,'var(--acc)',2):'')+'</div></div>'}).join('')+'</div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Recommendations</div>'+
[{t:'Enable SMS for critical alerts',d:'Get sync failures and anomalies via text',u:true},{t:'Review unread alerts',d:'2 new alerts need attention',u:true},{t:'Configure push notifications',d:'Instant alerts when app goes native'},{t:'Set quiet hours',d:'No alerts between 10pm-7am'}].map(function(r){return '<div class="ci" style="margin-bottom:6px;'+(r.u?'border-color:color-mix(in srgb,var(--acc) 15%,transparent);background:var(--accS)':'')+'"><div style="font-weight:700;font-size:11px;color:'+(r.u?'var(--acc)':'var(--t1)')+'">'+r.t+'</div><div class="sub" style="font-size:10px">'+r.d+'</div></div>'}).join('')+'</div>'+
'</div></div></div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="c">'+hd('Alerts & Notifications')+sNotifs()+pendingBadge('Email/SMS delivery backend')+'</div></div>'}


/* ========== CHARGEIQ — Expense Forensics ========== */
function rChargeIQ(){
var sampleCharges=[
{raw:'APCR*DIGITALRVRM',merchant:'Apple Card - Digital River',desc:'Software/App purchase via Apple payment system',cat:'Software',conf:92,phone:'1-800-275-2273',web:'apple.com/card'},
