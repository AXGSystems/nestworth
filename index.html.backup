/* ========== SVG CHART HELPERS ========== */
function svgLineChart(data,w,h,color,label,showArea){
  if(!data||!data.length)return '';
  w=w||400;h=h||160;color=color||'var(--acc)';
  var pad={t:10,r:10,b:28,l:10};
  var cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;
  var vals=data.map(function(d){return d.v||d.y||0});
  var mn=Math.min.apply(null,vals),mx=Math.max.apply(null,vals);
  var rng=mx-mn||1;
  var pts=data.map(function(d,i){
    var x=pad.l+(i/(data.length-1))*cw;
    var y=pad.t+ch-(((d.v||d.y||0)-mn)/rng)*ch;
    return {x:x,y:y};
  });
  var uid='lc'+Math.random().toString(36).substr(2,6);
  var pathD='M'+pts.map(function(p){return p.x+','+p.y}).join(' L');
  var areaD=pathD+' L'+pts[pts.length-1].x+','+(pad.t+ch)+' L'+pts[0].x+','+(pad.t+ch)+' Z';
  var labels=data.map(function(d,i){
    var x=pad.l+(i/(data.length-1))*cw;
    return '<text x="'+x+'" y="'+(h-4)+'" text-anchor="middle" fill="var(--t2)" font-size="9" font-weight="600">'+(d.m||d.x||'')+'</text>';
  });
  var dots=pts.map(function(p,i){
    var val=vals[i];
    return '<circle cx="'+p.x+'" cy="'+p.y+'" r="3.5" fill="'+color+'" stroke="var(--cardBg)" stroke-width="2" opacity="0"><animate attributeName="opacity" from="0" to="1" dur="0.3s" begin="'+(0.05*i)+'s" fill="freeze"/></circle>'+
    '<title>$'+val.toLocaleString()+'</title>';
  });
  var gridLines='';
  for(var gi=0;gi<=3;gi++){
    var gy=pad.t+(ch/3)*gi;
    gridLines+='<line x1="'+pad.l+'" y1="'+gy+'" x2="'+(w-pad.r)+'" y2="'+gy+'" stroke="var(--sep)" stroke-width="0.5"/>';
  }
  return '<svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto">'+
  '<defs><linearGradient id="'+uid+'" x1="0" y1="0" x2="0" y2="1">'+
  '<stop offset="0%" stop-color="'+color+'" stop-opacity="0.2"/>'+
  '<stop offset="100%" stop-color="'+color+'" stop-opacity="0"/>'+
  '</linearGradient></defs>'+
  gridLines+
  (showArea!==false?'<path d="'+areaD+'" fill="url(#'+uid+')"><animate attributeName="opacity" from="0" to="1" dur="0.6s" fill="freeze"/></path>':'')+
  '<path d="'+pathD+'" fill="none" stroke="'+color+'" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><animate attributeName="stroke-dashoffset" from="2000" to="0" dur="1s" fill="freeze"/></path>'+
  dots.join('')+
  labels.join('')+
  (label?'<text x="'+pad.l+'" y="'+(pad.t-2)+'" fill="var(--t2)" font-size="9" font-weight="600">'+label+'</text>':'')+
  '</svg>';
}

function svgBarChart(data,w,h,horizontal){
  if(!data||!data.length)return '';
  w=w||400;h=h||200;
  if(horizontal){
    var bh=Math.min(28,Math.floor((h-20)/data.length)-6);
    var pad={t:5,r:60,b:5,l:80};
    var cw=w-pad.l-pad.r;
    var maxVal=Math.max.apply(null,data.map(function(d){return d.max||d.value}));
    var bars=data.map(function(d,i){
      var y=pad.t+i*(bh+8);
      var bw=(d.value/(maxVal||1))*cw;
      var mw=d.max?((d.max/(maxVal||1))*cw):0;
      var c=d.color||'var(--acc)';
      var pct=d.max?Math.round((d.value/d.max)*100):100;
      return (d.max?'<rect x="'+pad.l+'" y="'+y+'" width="'+mw+'" height="'+bh+'" rx="4" fill="var(--sep)" opacity="0.5"/>':'')+
      '<rect x="'+pad.l+'" y="'+y+'" width="'+bw+'" height="'+bh+'" rx="4" fill="'+c+'"><title>'+d.label+': $'+d.value+(d.max?' of $'+d.max+' ('+pct+'%)':'')+'</title><animate attributeName="width" from="0" to="'+bw+'" dur="0.5s" begin="'+(0.05*i)+'s" fill="freeze"/></rect>'+
      '<text x="'+(pad.l-6)+'" y="'+(y+bh/2+4)+'" text-anchor="end" fill="var(--t1)" font-size="11" font-weight="600">'+d.label+'</text>'+
      '<text x="'+(pad.l+bw+6)+'" y="'+(y+bh/2+4)+'" fill="var(--t2)" font-size="10" font-weight="700">$'+d.value+(d.max?' ('+pct+'%)':'')+'</text>';
    });
    var th=pad.t+data.length*(bh+8);
    return '<svg viewBox="0 0 '+w+' '+th+'" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto">'+bars.join('')+'</svg>';
  }
  var pad2={t:10,r:10,b:28,l:10};
  var cw2=w-pad2.l-pad2.r,ch2=h-pad2.t-pad2.b;
  var maxV=Math.max.apply(null,data.map(function(d){return d.value||0}));
  var bw2=Math.min(40,Math.floor(cw2/data.length)-8);
  var bars2=data.map(function(d,i){
    var x=pad2.l+(i/(data.length-1||1))*cw2-bw2/2;
    if(data.length===1)x=pad2.l+cw2/2-bw2/2;
    var bh2=((d.value||0)/(maxV||1))*ch2;
    var y=pad2.t+ch2-bh2;
    var c=d.color||'var(--acc)';
    return '<rect x="'+x+'" y="'+y+'" width="'+bw2+'" height="'+bh2+'" rx="4" fill="'+c+'"><title>'+(d.label||'')+': $'+(d.value||0)+'</title><animate attributeName="height" from="0" to="'+bh2+'" dur="0.4s" begin="'+(0.04*i)+'s" fill="freeze"/><animate attributeName="y" from="'+(pad2.t+ch2)+'" to="'+y+'" dur="0.4s" begin="'+(0.04*i)+'s" fill="freeze"/></rect>'+
    '<text x="'+(x+bw2/2)+'" y="'+(h-4)+'" text-anchor="middle" fill="var(--t2)" font-size="9" font-weight="600">'+(d.label||'')+'</text>'+
    '<text x="'+(x+bw2/2)+'" y="'+(y-4)+'" text-anchor="middle" fill="var(--t1)" font-size="9" font-weight="700">$'+(d.value||0)+'</text>';
  });
  return '<svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto">'+bars2.join('')+'</svg>';
}

function svgDonut(segments,size,centerText,centerSub){
  if(!segments||!segments.length)return '';
  size=size||180;
  var total=segments.reduce(function(a,s){return a+(s.value||0)},0);
  if(!total)return '';
  var cx=size/2,cy=size/2,r=size*0.38,sw=size*0.12;
  var cumAngle=-90;
  var paths=segments.map(function(seg){
    var pct=(seg.value/total);
    var angle=pct*360;
    var startAngle=cumAngle;
    var endAngle=cumAngle+angle;
    cumAngle=endAngle;
    var startRad=startAngle*Math.PI/180;
    var endRad=endAngle*Math.PI/180;
    var x1=cx+r*Math.cos(startRad);
    var y1=cy+r*Math.sin(startRad);
    var x2=cx+r*Math.cos(endRad);
    var y2=cy+r*Math.sin(endRad);
    var largeArc=angle>180?1:0;
    return '<path d="M'+x1+','+y1+' A'+r+','+r+' 0 '+largeArc+' 1 '+x2+','+y2+'" fill="none" stroke="'+(seg.color||'var(--acc)')+'" stroke-width="'+sw+'" stroke-linecap="round"/>';
  });
  var legend=segments.map(function(seg){
    var pct=Math.round((seg.value/total)*100);
    return '<div style="display:flex;align-items:center;gap:6px;font-size:11px;margin-bottom:4px"><div style="width:8px;height:8px;border-radius:4px;background:'+(seg.color||'var(--acc)')+';flex-shrink:0"></div><span style="flex:1;color:var(--t2)">'+seg.label+'</span><span style="font-weight:700">'+pct+'%</span></div>';
  });
  return '<div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap"><div style="flex-shrink:0;position:relative;width:'+size+'px;height:'+size+'px">'+
  '<svg viewBox="0 0 '+size+' '+size+'" style="width:100%;height:100%">'+
  '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="var(--sep)" stroke-width="'+sw+'"/>'+
  paths.join('')+'</svg>'+
  (centerText?'<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center"><div style="font-size:'+Math.round(size*0.15)+'px;font-weight:900;letter-spacing:-1px">'+centerText+'</div>'+(centerSub?'<div style="font-size:'+Math.round(size*0.06)+'px;color:var(--t2);font-weight:500">'+centerSub+'</div>':'')+'</div>':'')+
  '</div><div style="flex:1;min-width:100px">'+legend.join('')+'</div></div>';
}

function svgAreaChart(data,w,h,color1,color2,label1,label2){
  if(!data||!data.length)return '';
  w=w||400;h=h||180;
  color1=color1||'var(--pos)';color2=color2||'var(--neg)';
  var pad={t:10,r:10,b:28,l:10};
  var cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;
  var allVals=[];
  data.forEach(function(d){allVals.push(d.inc||0);allVals.push(d.exp||0)});
  var mn=0,mx=Math.max.apply(null,allVals);
  var rng=mx-mn||1;
  function makePts(key){
    return data.map(function(d,i){
      var x=pad.l+(i/(data.length-1||1))*cw;
      var y=pad.t+ch-((d[key]-mn)/rng)*ch;
      return {x:x,y:y};
    });
  }
  var pts1=makePts('inc'),pts2=makePts('exp');
  var uid='ac'+Math.random().toString(36).substr(2,6);
  function buildArea(pts,color,gid){
    var pathD='M'+pts.map(function(p){return p.x+','+p.y}).join(' L');
    var areaD=pathD+' L'+pts[pts.length-1].x+','+(pad.t+ch)+' L'+pts[0].x+','+(pad.t+ch)+' Z';
    return '<defs><linearGradient id="'+gid+'" x1="0" y1="0" x2="0" y2="1">'+
    '<stop offset="0%" stop-color="'+color+'" stop-opacity="0.25"/>'+
    '<stop offset="100%" stop-color="'+color+'" stop-opacity="0.02"/>'+
    '</linearGradient></defs>'+
    '<path d="'+areaD+'" fill="url(#'+gid+')"/>'+
    '<path d="'+pathD+'" fill="none" stroke="'+color+'" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';
  }
  var labels=data.map(function(d,i){
    var x=pad.l+(i/(data.length-1||1))*cw;
    return '<text x="'+x+'" y="'+(h-4)+'" text-anchor="middle" fill="var(--t2)" font-size="9" font-weight="600">'+(d.m||'')+'</text>';
  });
  return '<svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto">'+
  buildArea(pts1,color1,uid+'_1')+buildArea(pts2,color2,uid+'_2')+labels.join('')+
  '<text x="'+(w-pad.r)+'" y="14" text-anchor="end" fill="'+color1+'" font-size="9" font-weight="700">'+(label1||'Income')+'</text>'+
  '<text x="'+(w-pad.r)+'" y="26" text-anchor="end" fill="'+color2+'" font-size="9" font-weight="700">'+(label2||'Expenses')+'</text>'+
  '</svg>';
}

function svgSparkline(data,w,h,color){
  if(!data||!data.length)return '';
  w=w||60;h=h||20;color=color||'var(--acc)';
  var vals=data.map(function(d){return typeof d==='number'?d:(d.v||d.y||0)});
  var mn=Math.min.apply(null,vals),mx=Math.max.apply(null,vals),rng=mx-mn||1;
  var pts=vals.map(function(v,i){
    return (i/(vals.length-1))*w+','+( h-((v-mn)/rng)*h*0.8-h*0.1);
  }).join(' ');
  return '<svg width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'"><polyline points="'+pts+'" fill="none" stroke="'+color+'" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
}

function svgStackedBarChart(data,w,h,keys,colors,labels){
  if(!data||!data.length)return '';
  w=w||400;h=h||200;
  var pad={t:10,r:10,b:28,l:10};
  var cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;
  var maxTotal=0;
  data.forEach(function(d){
    var t=0;keys.forEach(function(k){t+=(d[k]||0)});
    if(t>maxTotal)maxTotal=t;
  });
  var bw=Math.min(44,Math.floor(cw/data.length)-8);
  var bars=data.map(function(d,i){
    var x=pad.l+(i+0.5)*(cw/data.length)-bw/2;
    var cumH=0;
    var rects=keys.map(function(k,ki){
      var val=d[k]||0;
      var bh=(val/(maxTotal||1))*ch;
      var y=pad.t+ch-cumH-bh;
      cumH+=bh;
      return '<rect x="'+x+'" y="'+y+'" width="'+bw+'" height="'+bh+'" rx="2" fill="'+(colors[ki]||'var(--acc)')+'"><title>'+(labels?labels[ki]:k)+': $'+val+'</title></rect>';
    });
    return rects.join('')+
    '<text x="'+(x+bw/2)+'" y="'+(h-4)+'" text-anchor="middle" fill="var(--t2)" font-size="9" font-weight="600">'+(d.m||'')+'</text>';
  });
  var legendHtml=keys.map(function(k,ki){
    return '<span style="display:inline-flex;align-items:center;gap:3px;font-size:10px;margin-right:10px"><span style="width:8px;height:8px;border-radius:2px;background:'+(colors[ki]||'var(--acc)')+'"></span>'+(labels?labels[ki]:k)+'</span>';
  }).join('');
  return '<div style="margin-bottom:4px">'+legendHtml+'</div>'+
  '<svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="xMidYMid meet" style="width:100%;height:auto">'+bars.join('')+'</svg>';
}

function trendIndicator(current,previous,prefix,suffix){
  prefix=prefix||'';suffix=suffix||'';
  if(previous===0)return '';
  var pctChange=Math.round(((current-previous)/Math.abs(previous))*100);
  var isUp=pctChange>=0;
  var arrow=isUp?'<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>':'<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>';
  return '<span class="trend '+(isUp?'up':'down')+'">'+arrow+' '+prefix+(isUp?'+':'')+pctChange+suffix+'</span>';
}

var _billsCalendarCache=null;
function buildBillsCalendarSVG(){
  if(_billsCalendarCache)return _billsCalendarCache;
  var billDays={1:{n:'Mortgage',a:2000},5:{n:'Insurance',a:184},10:{n:'Electric',a:145},12:{n:'Water',a:65},15:{n:'Internet+Car',a:474},18:{n:'Phone',a:140},20:{n:'Gym',a:50},25:{n:'Student Loans',a:320}};
  var today=15;
  var daysInMonth=30;
  var startDay=1;
  var dayNames=['S','M','T','W','T','F','S'];
  var html='<div class="cal-grid">';
  dayNames.forEach(function(d){html+='<div class="cal-header">'+d+'</div>'});
  for(var e=0;e<startDay;e++){html+='<div class="cal-day empty"></div>'}
  for(var d=1;d<=daysInMonth;d++){
    var hasBill=billDays[d];
    var isToday=d===today;
    html+='<div class="cal-day'+(hasBill?' has-bill':'')+(isToday?' today':'')+'"'+(hasBill?' title="'+hasBill.n+': $'+hasBill.a+'"':'')+'>'+d+(hasBill?'<div class="cal-dot"></div>':'')+'</div>';
  }
  html+='</div>';
  _billsCalendarCache=html;
  return html;
}

/* XSS prevention */
function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}

/* Related Pages helper */
function relatedPages(links){
  return '<div class="c" style="margin-top:8px"><div style="font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px">See Also</div><div class="related-pages">'+
  links.map(function(l){return '<button class="related-page-chip" onclick="'+(l.tab?"gt('"+l.tab+"')":"gp('"+l.pg+"')")+'">'+l.label+' &rarr;</button>'}).join('')+
  '</div></div>';
}

/* Quick Links grid helper */
function quickLinksGrid(){
  var links=[
    {label:'ChargeIQ',pg:'chargeiq',bg:'var(--accS)',iconColor:'var(--acc)',iconPath:icons.search},
    {label:'Weather',pg:'weatherforecast',bg:'var(--posBg)',iconColor:'var(--pos)',iconPath:icons.cloudSun},
    {label:'NW Score',pg:'nestworthscore',bg:'var(--warnBg)',iconColor:'var(--warn)',iconPath:icons.barChart2},
    {label:'Credit',pg:'credithealth',bg:'color-mix(in srgb,var(--info) 10%,transparent)',iconColor:'var(--info)',iconPath:icons.gauge},
    {label:'Bill Audit',pg:'billaudit',bg:'var(--posBg)',iconColor:'var(--pos)',iconPath:icons.scissors},
    {label:'Subscriptions',pg:'subscriptions',bg:'var(--negBg)',iconColor:'var(--neg)',iconPath:icons.scissors},
    {label:'Debt Plan',pg:'debtpaydown',bg:'var(--negBg)',iconColor:'var(--neg)',iconPath:icons.dollar},
    {label:'Export',pg:'exportdata',bg:'var(--accS)',iconColor:'var(--acc)',iconPath:icons.download}
  ];
  return '<div class="quick-links-grid">'+links.map(function(l){
    return '<div class="quick-link-item" onclick="gp(\''+l.pg+'\')"><div class="ql-icon" style="background:'+l.bg+'">'+ic(l.iconPath,16,l.iconColor,1.5)+'</div><div class="ql-label">'+l.label+'</div></div>';
  }).join('')+'</div>';
}

/* What-If scenario helper for Goals */
function whatIfScenarios(){
  var scenarios=[
    {q:'Save $100 more/month?',a:'You\'d reach Emergency Fund 4 months sooner and save an extra $1,200/year.'},
    {q:'Cut subscriptions by $50/month?',a:'That\'s $600/year. Invested at 7%, it becomes $8,600 over 10 years.'},
    {q:'Increase 401(k) by 5%?',a:'At your salary, that\'s ~$350/month pre-tax. $42k more by retirement (30yr).'},
    {q:'Pay $200 extra on debt/month?',a:'Debt-free 4.2 months sooner. Save $510 in interest payments.'}
  ];
  return '<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">What If...?</span></div>'+
  '<div class="sub" style="margin-bottom:10px">Explore how small changes compound over time</div>'+
  scenarios.map(function(s){
    return '<div class="ci" style="margin-bottom:6px;cursor:pointer" onclick="os(\'What If Analysis\',\'<div style=&quot;padding:8px&quot;><div style=&quot;font-weight:800;font-size:14px;margin-bottom:8px&quot;>'+s.q.replace(/'/g,"\\&#39;")+'</div><div class=&quot;sub&quot; style=&quot;line-height:1.6&quot;>'+s.a.replace(/'/g,"\\&#39;")+'</div></div>\')"><div class="r" style="gap:8px">'+ic(icons.zap,14,'var(--acc)',1.5)+
    '<div style="flex:1"><div style="font-weight:700;font-size:12px;color:var(--acc)">'+s.q+'</div><div class="sub" style="font-size:10px">'+s.a.substring(0,60)+'...</div></div>'+ic(icons.chev,12,'var(--t3)')+'</div></div>';
  }).join('')+'</div>';
}

/* Sheet */
function os(t,c){$('shc').innerHTML='<div class="sh-h"></div><div class="shd" style="margin-bottom:14px">'+esc(t)+'</div><div class="fi">'+c+'</div><div class="esc-hint">Press Esc to close</div>';$('sho').classList.add('open');document.body.style.overflow='hidden'}
function closeSheet(){$('sho').classList.remove('open');document.body.style.overflow=''}

/* Navigation */
function gt(t){ct=t;pg=null;closeSheet();closeDrawer();rr()}
function gp(p){pg=p;closeSheet();closeDrawer();rr()}
function gb(){pg=null;closeSheet();rr()}

/* Drawer */
function openDrawer(){drawerOpen=true;$('drawer').classList.add('open');$('drawerOverlay').classList.add('open');document.body.style.overflow='hidden'}
function closeDrawer(){drawerOpen=false;if($('drawer'))$('drawer').classList.remove('open');if($('drawerOverlay'))$('drawerOverlay').classList.remove('open');if(!$('sho').classList.contains('open'))document.body.style.overflow=''}

/* Sidebar toggle */
function toggleSidebar(){sidebarCollapsed=!sidebarCollapsed;try{localStorage.setItem('nw-sidebar-collapsed',sidebarCollapsed)}catch(e){}var sb=$('sidebar');if(sb){sb.classList.toggle('collapsed',sidebarCollapsed)}rr()}

/* ========== ICONS ========== */
var icons={
  home:function(c,f){return'<svg width="22" height="22" viewBox="0 0 24 24" fill="'+(f?'currentColor':'none')+'" fill-opacity="'+(f?0.12:0)+'" stroke="'+c+'" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>'},
  budget:function(c){return'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="'+c+'" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>'},
  goals:function(c,f){return'<svg width="22" height="22" viewBox="0 0 24 24" fill="'+(f?'currentColor':'none')+'" fill-opacity="'+(f?0.12:0)+'" stroke="'+c+'" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>'},
  track:function(c){return'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="'+c+'" stroke-width="1.5" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>'},
