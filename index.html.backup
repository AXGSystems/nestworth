'<div class="ci" style="margin-top:6px;display:flex;align-items:center;gap:6px;background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);cursor:pointer" onclick="os(\'Deleted Transactions\',sDel())"><span style="font-size:11px;font-weight:700;color:var(--neg)">3 Deleted Transactions</span><span class="sub">Can restore</span></div></div>'+
'</div>'}

/* Sync Health page */
function rSyncHealth(){
var syncAccounts=[{b:'Chase Checking',l:'2h',s:'g',v:'$5,360'},{b:'Chase Savings',l:'2h',s:'g',v:'$12,400'},{b:'Capital One',l:'3d',s:'y',v:'$2,100'},{b:'Cap One Savings',l:'47d',s:'r',v:'$8,200',f:true},{b:'Ally Invest',l:'1d',s:'g',v:'$26,500'},{b:'Credit Cards',l:'6h',s:'g',v:'-$1,200'}];
var syncHistory=[{m:'Mar 16',v:6},{m:'Mar 23',v:5},{m:'Mar 30',v:6},{m:'Apr 6',v:5},{m:'Apr 13',v:4},{m:'Apr 15',v:5}];
var mobileList=syncAccounts.map(function(a){return '<div class="ci" style="margin-bottom:4px;display:flex;align-items:center;gap:8px;'+(a.s==='r'?'border-color:color-mix(in srgb,var(--neg) 15%,transparent);background:var(--negBg)':a.s==='y'?'border-color:color-mix(in srgb,var(--warn) 15%,transparent);background:var(--warnBg)':'')+';padding:8px 10px;cursor:pointer" onclick="os(\''+a.b+'\',sSyncD(\''+a.b+'\',\''+a.l+'\',\''+a.s+'\',\''+a.v+'\'))"><div class="dot" style="width:6px;height:6px;background:'+(a.s==='g'?'var(--pos)':a.s==='y'?'var(--warn)':'var(--neg)')+'"></div><div style="flex:1"><div style="font-weight:600;font-size:11px">'+a.b+'</div><div class="sub">'+a.l+' ago</div></div><span style="font-size:11px;font-weight:700;color:'+(a.s==='r'?'var(--neg)':'var(--t1)')+';flex-shrink:0">'+a.v+'</span>'+(a.f?bg('ACT','var(--neg)'):'')+'</div>'}).join('');

if(isDesktop()){
return '<div class="fi">'+
'<div class="stat-row cols-4">'+
'<div class="stat-card"><div class="stat-label">Linked Accounts</div><div class="stat-value">6</div><div class="sub">across 3 institutions</div></div>'+
'<div class="stat-card"><div class="stat-label">Syncing Well</div><div class="stat-value" style="color:var(--pos)">4</div><div class="sub">data is fresh</div></div>'+
'<div class="stat-card"><div class="stat-label">Needs Refresh</div><div class="stat-value" style="color:var(--warn)">1</div><div class="sub">3 days behind</div></div>'+
'<div class="stat-card"><div class="stat-label">Disconnected</div><div class="stat-value" style="color:var(--neg)">1</div><div class="sub">47 days stale</div></div>'+
'</div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container"><div class="chart-title">Connection Health</div>'+
'<table class="data-table"><thead><tr><th>Account</th><th>Last Sync</th><th>Status</th><th>Balance</th><th>Actions</th></tr></thead><tbody>'+
syncAccounts.map(function(a){return '<tr onclick="os(\''+a.b+'\',sSyncD(\''+a.b+'\',\''+a.l+'\',\''+a.s+'\',\''+a.v+'\'))" style="cursor:pointer"><td style="font-weight:600">'+a.b+'</td><td>'+a.l+' ago</td><td><div class="dot" style="width:8px;height:8px;display:inline-block;background:'+(a.s==='g'?'var(--pos)':a.s==='y'?'var(--warn)':'var(--neg)')+'"></div> '+(a.s==='g'?'Healthy':a.s==='y'?'Warning':'Stale')+'</td><td class="amount">'+a.v+'</td><td>'+(a.s!=='g'?'<button class="btn-pill" style="font-size:10px">'+(a.s==='r'?'Reconnect':'Refresh')+'</button>':'<span class="sub">OK</span>')+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container"><div class="chart-title">Sync Activity (6 Weeks)</div><div class="chart-subtitle">Fewer syncs recently &mdash; Cap One disconnect is pulling the average down</div>'+
svgLineChart(syncHistory,500,160,'var(--acc)','Syncs/Week')+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Accounts That Need You</div>'+
'<div class="ci" style="background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);margin-bottom:8px"><div style="font-weight:700;font-size:12px;color:var(--neg)">Cap One Savings</div><div class="sub">47 days without sync</div><div class="sub">Balance may be inaccurate by $200+</div><button class="btn-pill" style="margin-top:8px;font-size:10px;background:var(--negBg);color:var(--neg)">Force Reconnect</button></div>'+
'<div class="ci" style="background:var(--warnBg);border-color:color-mix(in srgb,var(--warn) 12%,transparent)"><div style="font-weight:700;font-size:12px;color:var(--warn)">Capital One</div><div class="sub">3 days since last sync</div><button class="btn-pill" style="margin-top:8px;font-size:10px">Refresh Now</button></div></div>'+
'<div class="chart-container"><div class="chart-title">Data Integrity Checks</div>'+
[{n:'Transaction matching',s:true},{n:'Balance reconciliation',s:true},{n:'Category sync',s:true},{n:'Duplicate detection',s:true},{n:'Transfer recognition',s:false}].map(function(cr){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;flex:1">'+cr.n+'</span>'+(cr.s?bg('Active','var(--pos)'):bg('Off','var(--t3)'))+'</div>'}).join('')+'</div>'+
'<div class="chart-container"><div class="chart-title">Reconnection History</div>'+
[{d:'Mar 14',a:'Cap One Savings',w:'Von',r:'Success'},{d:'Feb 20',a:'Chase Checking',w:'System',r:'Auto'},{d:'Jan 15',a:'Ally Invest',w:'Von',r:'Success'}].map(function(rh){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span class="sub" style="width:48px">'+rh.d+'</span><span style="font-size:11px;flex:1;font-weight:600">'+rh.a+'</span>'+bg(rh.r,'var(--pos)')+'</div>'}).join('')+'</div>'+
pendingBadge('Plaid real-time sync')+
'</div></div></div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs"><div class="r" style="margin-bottom:8px">'+hd('Sync Health')+'<div style="margin-left:auto;display:flex;gap:3px">'+bg('4 ok','var(--pos)')+bg('1 stale','var(--neg)')+'</div></div>'+mobileList+'</div>'+
pendingBadge('Plaid real-time sync')+
'</div>'}

/* Income Cadence page */
function rIncomeCadence(){
