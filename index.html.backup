'<div class="ci" style="display:flex;align-items:center;gap:10px;margin-bottom:12px"><div style="width:50px;height:65px;border-radius:8px;background:var(--accS);display:flex;align-items:center;justify-content:center;flex-shrink:0">'+ic(icons.receipt,24,'var(--acc)',1.5)+'</div><div style="flex:1"><div style="font-weight:800;font-size:16px;color:var(--pos)">$145.00</div><div style="font-weight:700;font-size:14px;margin-top:2px">Pepco Electric</div><div class="sub" style="margin-top:2px">Apr 13 &middot; Account ending 4821</div></div></div>'+
'<div style="font-weight:700;font-size:12px;margin-bottom:6px">OCR Results</div>'+
'<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px">'+[{l:'Merchant',v:'Pepco'},{l:'Amount',v:'$145.00'},{l:'Date',v:'Apr 13'},{l:'Category',v:'Utilities'}].map(function(f){return '<div class="ci" style="padding:8px"><div class="sub" style="font-size:9px">'+f.l+'</div><div style="font-size:12px;font-weight:700">'+f.v+'</div></div>'}).join('')+'</div>'+
'<div style="display:flex;gap:8px;margin-top:12px"><button class="btn" style="flex:1;border-radius:22px;height:44px;font-size:13px" onclick="os(\'Attached!\',sDone(\'Receipt matched to Electric Bill $145.00\'))">Attach to Transaction</button><button class="btn-outline" style="flex:1;border-radius:22px">Send to Caroline</button></div></div></div>'+
'<div class="chart-container"><div class="chart-title">Bulk Upload</div>'+
'<div class="scan-area" style="padding:20px;opacity:0.4"><div style="font-size:13px;font-weight:600">Drag & drop multiple receipts here</div><div class="sub" style="margin-top:4px">Supports JPG, PNG, PDF</div></div></div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Recent Scans</div>'+
'<table class="data-table"><thead><tr><th>Receipt</th><th>Amount</th><th>Date</th><th>Status</th></tr></thead><tbody>'+
recentScans.map(function(s){return '<tr><td style="font-weight:600">'+s.n+'</td><td>'+s.a+'</td><td>'+s.d+'</td><td>'+(s.m?bg('Matched','var(--pos)'):bg('Unmatched','var(--warn)'))+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container"><div class="chart-title">Scan Activity</div>'+
svgLineChart([{m:"Jan",v:2},{m:"Feb",v:4},{m:"Mar",v:6},{m:"Apr",v:8}],340,100,'var(--acc)','Scans/Month')+'</div>'+
'<div class="chart-container"><div class="chart-title">OCR Accuracy</div>'+
'<div style="text-align:center;margin:8px 0"><div style="font-size:24px;font-weight:900;color:var(--pos)">94%</div><div class="sub">average match accuracy</div></div>'+
[{l:'Merchant',a:'96%'},{l:'Amount',a:'98%'},{l:'Date',a:'88%'},{l:'Category',a:'92%'}].map(function(o){return '<div class="r" style="padding:4px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:11px;flex:1">'+o.l+'</span><span style="font-size:11px;font-weight:700;color:var(--pos)">'+o.a+'</span></div>'}).join('')+'</div>'+
'</div></div></div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs" style="text-align:center;padding:20px">'+hd('Receipt Scanner')+'<div class="sub" style="margin-top:-8px;margin-bottom:16px">Snap a receipt, auto-match it to a transaction</div>'+
pendingBadge('Capacitor/native camera')+scanArea+'</div>'+
'<div id="scanResult" style="display:none"><div class="cs">'+hd('Receipt Detected')+
'<div class="ci" style="display:flex;align-items:center;gap:10px;margin-bottom:12px"><div style="width:50px;height:65px;border-radius:8px;background:var(--accS);display:flex;align-items:center;justify-content:center;flex-shrink:0">'+ic(icons.receipt,24,'var(--acc)',1.5)+'</div><div style="flex:1"><div style="font-weight:800;font-size:16px;color:var(--pos)">$145.00</div><div style="font-weight:700;font-size:14px;margin-top:2px">Pepco Electric</div></div></div></div></div>'+
'<div class="c">'+hd('Recent Scans')+recentScans.slice(0,3).map(function(s){return '<div class="tr">'+ic(icons.receipt,14,'var(--acc)',1.5)+'<div style="flex:1"><div style="font-weight:600;font-size:12px">'+s.n+'</div><div class="sub">'+s.d+' &middot; '+s.a+'</div></div>'+(s.m?bg('Matched','var(--pos)'):bg('Unmatched','var(--warn)'))+'</div>'}).join('')+'</div>'+
'</div>'}
function doScan(){var a=$('scanArea');if(!a)return;a.innerHTML='<div style="padding:20px"><div style="font-weight:700;font-size:14px;color:var(--acc)">Scanning...</div><div style="margin:12px auto;width:40px;height:40px;border:3px solid var(--sep);border-top:3px solid var(--acc);border-radius:50%;animation:spin 1s linear infinite"></div></div>';setTimeout(function(){var sr=$('scanResult');if(sr)sr.style.display='block';if(a)a.style.display='none'},1500)}

/* Settings page */
function rSettings(){return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs"><div class="r" style="gap:12px;margin-bottom:14px"><div style="width:48px;height:48px;border-radius:24px;background:var(--acc);display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;font-weight:800">VS</div><div style="flex:1"><div style="font-size:16px;font-weight:800">Von & Caroline</div><div class="sub">Household &middot; Since Jan 2024</div></div></div>'+
'<div style="display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);gap:6px"><div class="ci" style="text-align:center;padding:8px"><div class="sub" style="font-size:9px">Net Worth</div><div style="font-size:14px;font-weight:800;color:var(--acc)">$82.4k</div></div><div class="ci" style="text-align:center;padding:8px"><div class="sub" style="font-size:9px">Nests</div><div style="font-size:14px;font-weight:800">6</div></div><div class="ci" style="text-align:center;padding:8px"><div class="sub" style="font-size:9px">Saved</div><div style="font-size:14px;font-weight:800;color:var(--pos)">$6.1k</div></div></div></div>'+

/* Theme Picker */
'<div class="cs">'+hd('Appearance')+
'<div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:6px">'+
[{n:'Emerald',k:'emerald',c1:'#1a5e3a',c2:'#c8a848'},{n:'Light',k:'light',c1:'#f2f2f7',c2:'#007aff'},{n:'Dark',k:'dark',c1:'#000',c2:'#0a84ff'},{n:'Midnight',k:'midnight',c1:'#0a0e1a',c2:'#6c8fff'},{n:'Gold',k:'gold',c1:'#12100b',c2:'#d4a853'}].map(function(t){return '<div style="text-align:center;cursor:pointer;min-width:0" onclick="setTheme(\''+t.k+'\')"><div style="width:100%;aspect-ratio:1;border-radius:12px;background:linear-gradient(135deg,'+t.c1+','+t.c2+');border:2.5px solid '+(theme===t.k?'var(--acc)':'transparent')+';transition:border 0.2s ease;display:flex;align-items:center;justify-content:center">'+(theme===t.k?ic(icons.check,16,'#fff',3):'')+'</div><div style="font-size:10px;font-weight:600;margin-top:4px;color:'+(theme===t.k?'var(--acc)':'var(--t2)')+'">'+t.n+'</div></div>'}).join('')+'</div></div>'+

/* Alerts */
'<div class="cs">'+hd('Email & SMS Alerts')+
'<div class="r" style="padding:10px 0;border-bottom:0.5px solid var(--sep)"><div style="flex:1;display:flex;align-items:center;gap:8px">'+ic(icons.mail,16,'var(--acc)',1.5)+'<div><div style="font-weight:600;font-size:12px">Email Alerts</div><div class="sub">'+alertPrefs.emailAddr+'</div></div></div>'+tg(alertPrefs.email,false,'togEmail')+'</div>'+
'<div class="r" style="padding:10px 0;border-bottom:0.5px solid var(--sep)"><div style="flex:1;display:flex;align-items:center;gap:8px">'+ic(icons.phone,16,'var(--acc)',1.5)+'<div><div style="font-weight:600;font-size:12px">SMS Alerts</div><div class="sub">'+(alertPrefs.phone||'Add phone number')+'</div></div></div>'+tg(alertPrefs.sms,false,'togSMS')+'</div>'+
pendingBadge('Email/SMS backend')+
'<div style="margin-top:10px;font-weight:700;font-size:11px;margin-bottom:6px">Alert Types</div>'+
[['overspend','Category Overspend'],['sync','Account Sync Issues'],['bills','Bill Due Reminders'],['goals','Goal Milestones'],['anomaly','Anomaly Detection'],['velocity','Spending Velocity'],['weekly','Weekly Summary']].map(function(kv){return '<div class="r" style="padding:8px 0;min-height:44px;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;flex:1">'+kv[1]+'</span>'+tg(alertPrefs.types[kv[0]],false,'togAlert_'+kv[0])+'</div>'}).join('')+
'<button class="btn btn-full" style="margin-top:12px;border-radius:22px;height:44px;font-size:13px" onclick="saveAlertSettings()">Save Alert Preferences</button></div>'+

/* Ads & Monetization */
'<div class="cs">'+hd('Ads & Monetization')+
'<div class="sub" style="margin-top:-8px;margin-bottom:10px">Control how sponsored content appears</div>'+
'<div class="r" style="padding:8px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;font-weight:600;flex:1">Native Ad Cards</span>'+tg(adPrefs.showNativeAds,false,'togAdNative')+'</div>'+
'<div class="r" style="padding:8px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;font-weight:600;flex:1">Premium Upgrade Banner</span>'+tg(adPrefs.showPremiumBanner,false,'togAdPremium')+'</div>'+
'<div class="r" style="padding:8px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;font-weight:600;flex:1">Partner Financial Offers</span>'+tg(adPrefs.showPartnerOffers,false,'togAdPartner')+'</div>'+
'<button class="btn btn-full" style="margin-top:12px;border-radius:22px;height:44px;font-size:13px" onclick="saveAdSettings()">Save Ad Preferences</button></div>'+

/* Connected Accounts */
'<div class="cs">'+hd('Connected Accounts')+
[{b:'Chase',t:'3 accounts',s:'ok'},{b:'Capital One',t:'2 accounts',s:'issue'},{b:'Ally',t:'1 account',s:'ok'},{b:'Amex',t:'1 account',s:'ok'}].map(function(a){return '<div class="ci" style="margin-bottom:4px;'+(a.s==='issue'?'border-color:color-mix(in srgb,var(--neg) 15%,transparent);background:var(--negBg)':'')+'"><div class="r" style="gap:8px"><div style="flex:1"><div class="r" style="gap:3px"><span style="font-weight:700;font-size:12px">'+a.b+'</span>'+bg(a.s==='ok'?'Connected':'Issue',a.s==='ok'?'var(--pos)':'var(--neg)')+'</div><div class="sub">'+a.t+'</div></div><button class="btn-pill" style="font-size:10px">'+(a.s==='issue'?'Fix':'Manage')+'</button></div></div>'}).join('')+
'<button class="btn-gold btn-full" style="margin-top:8px;padding:12px;font-size:13px;border-radius:22px" onclick="os(\'Connect Bank\',sCon())">+ Connect New Account</button>'+
pendingBadge('Plaid integration')+'</div>'+

/* Preferences */
'<div class="c">'+hd('Preferences')+
['Transparency Mode','Notifications','Biometric Lock','Smart Categories','Duplicate Detection','Transfer Recognition'].map(function(p,i){return '<div class="r" style="padding:8px 0;border-bottom:0.5px solid var(--sep)"><span style="font-size:12px;font-weight:600;flex:1">'+p+'</span>'+tg(true)+'</div>'+(p==='Biometric Lock'?pendingBadge('native biometrics'):'')+(p==='Notifications'?pendingBadge('push notification service'):'')}).join('')+'</div>'+

/* Data */
'<div class="c">'+hd('Data & Export')+
['Export All Data (CSV/PDF)','Download Audit Trail','Print Budget Report','Request Data Deletion','Privacy Policy','Security (SOC 2 / Plaid)'].map(function(item){return '<div class="tr"><span style="font-size:12px;font-weight:600;flex:1">'+item+'</span>'+ic(icons.chev,14,'var(--t3)')+'</div>'}).join('')+
pendingBadge('server-side generation')+'</div>'+

'<div class="c" style="text-align:center;padding:16px"><div style="font-size:20px;font-weight:800;letter-spacing:-0.5px"><span>Nest</span><span style="color:var(--gold)">Worth</span></div><div class="sub" style="margin-top:2px">v4.2 &middot; Built for two, trusted by both</div></div>'+
'<button class="btn-danger btn-full" style="border-radius:22px;padding:12px;font-weight:700;font-size:13px">Sign Out</button>'+
'</div>'}

function saveAdSettings(){
  var n=$('togAdNative'),p=$('togAdPremium'),o=$('togAdPartner');
  if(n)adPrefs.showNativeAds=n.classList.contains('on');
  if(p)adPrefs.showPremiumBanner=p.classList.contains('on');
  if(o)adPrefs.showPartnerOffers=o.classList.contains('on');
  saveAdPrefs();os('Saved',sDone('Ad preferences updated.'));
}

/* Partner Transparency page */
function rPartnerTransparency(){
var auditTrail=[{a:'Disconnected',d:'Cap One Savings',w:'Caroline',t:'Mar 12',f:true},{a:'Tx Deleted',d:'Target $84.50',w:'Caroline',t:'Mar 10',f:true},{a:'Reconnected',d:'Cap One Savings',w:'Von',t:'Mar 14'},{a:'Category Edit',d:'Amazon $150',w:'Caroline',t:'Feb 25'},{a:'Export',d:'Q1 CSV',w:'Von',t:'Feb 20'},{a:'Budget Edit',d:'Entertainment $150',w:'Von',t:'Feb 18'},{a:'Nest Created',d:'Wedding Fund',w:'Caroline',t:'Feb 10'},{a:'Login',d:'Mobile device',w:'Von',t:'Feb 8'}];
var mobileContent=auditTrail.slice(0,5).map(function(e){return '<div class="tr" style="gap:6px" onclick="os(\'Audit: '+e.a+'\',sAuditDetail(\''+e.a+'\',\''+e.d+'\',\''+e.w+'\',\''+e.t+'\','+(e.f||false)+'))"><div style="width:24px;height:24px;border-radius:6px;background:'+(e.f?'var(--negBg)':'var(--posBg)')+';display:flex;align-items:center;justify-content:center;flex-shrink:0">'+(e.f?ic(icons.flag,10,'var(--neg)',1.5):ic(icons.check,10,'var(--pos)',3))+'</div><div style="flex:1"><div style="font-weight:600;font-size:11px;color:'+(e.f?'var(--neg)':'var(--t1)')+'">'+e.a+'</div><div class="sub">'+e.d+' &middot; '+e.w+' &middot; '+e.t+'</div></div></div>'}).join('');

if(isDesktop()){
var auditByMonth=[{m:'Jan',v:12},{m:'Feb',v:18},{m:'Mar',v:24},{m:'Apr',v:8}];
var trustMatrix=[{f:'Full Tx Visibility',v:'Both',c:'Both',s:'Active'},{f:'Account Connect/Disconnect',v:'Logged',c:'Logged',s:'Active'},{f:'Deletion Recovery',v:'Enabled',c:'Enabled',s:'Active'},{f:'Category Edits',v:'Tracked',c:'Tracked',s:'Active'},{f:'Budget Changes',v:'Tracked',c:'Tracked',s:'Active'},{f:'Export History',v:'Logged',c:'Logged',s:'Active'},{f:'Login Alerts',v:'On',c:'On',s:'Active'},{f:'Nest Changes',v:'Tracked',c:'Tracked',s:'Active'}];
return '<div class="fi">'+
'<div class="stat-row cols-4">'+
'<div class="stat-card"><div class="stat-label">Trust Score</div><div class="stat-value" style="color:var(--pos)">94</div><div class="stat-change up">Excellent</div></div>'+
'<div class="stat-card"><div class="stat-label">Audit Events</div><div class="stat-value">'+auditTrail.length+'</div><div class="stat-change">Last 90 days</div></div>'+
'<div class="stat-card"><div class="stat-label">Flags</div><div class="stat-value" style="color:var(--neg)">2</div><div class="stat-change down">Needs review</div></div>'+
'<div class="stat-card"><div class="stat-label">Deleted TXs</div><div class="stat-value" style="color:var(--neg)">3</div><div class="stat-change">All recoverable</div></div>'+
'</div>'+
'<div class="dash-row"><div class="dash-main">'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Trust Score Visualization</div><div class="chart-subtitle">Composite score based on transparency, sync health, and flag resolution</div>'+
'<div style="display:flex;gap:20px;align-items:center;padding:8px 0"><div style="text-align:center"><div style="width:100px;height:100px;border-radius:50px;background:conic-gradient(var(--pos) 94%,var(--sep) 0);display:flex;align-items:center;justify-content:center;margin:0 auto"><div style="width:76px;height:76px;border-radius:38px;background:var(--bgE);display:flex;flex-direction:column;align-items:center;justify-content:center"><div style="font-size:28px;font-weight:900;color:var(--pos)">94</div><div class="sub">/ 100</div></div></div></div>'+
'<div style="flex:1"><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">'+
[{l:'Visibility',v:100,c:'var(--pos)'},{l:'Sync Health',v:80,c:'var(--warn)'},{l:'Flag Resolution',v:90,c:'var(--pos)'},{l:'Data Integrity',v:100,c:'var(--pos)'}].map(function(m){return '<div><div class="r" style="justify-content:space-between;margin-bottom:2px"><span style="font-size:10px;font-weight:600">'+m.l+'</span><span style="font-size:10px;font-weight:700;color:'+m.c+'">'+m.v+'%</span></div>'+br(m.v,m.c,4)+'</div>'}).join('')+
'</div></div></div></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Audit Trail</div>'+
'<table class="data-table"><thead><tr><th></th><th>Action</th><th>Detail</th><th>Person</th><th>Date</th><th>Status</th></tr></thead><tbody>'+
auditTrail.map(function(e){return '<tr style="cursor:pointer" onclick="os(\'Audit: '+e.a+'\',sAuditDetail(\''+e.a+'\',\''+e.d+'\',\''+e.w+'\',\''+e.t+'\','+(e.f||false)+'))"><td><div style="width:20px;height:20px;border-radius:5px;background:'+(e.f?'var(--negBg)':'var(--posBg)')+';display:flex;align-items:center;justify-content:center">'+(e.f?ic(icons.flag,8,'var(--neg)',1.5):ic(icons.check,8,'var(--pos)',3))+'</div></td><td style="font-weight:700;color:'+(e.f?'var(--neg)':'var(--t1)')+'">'+e.a+'</td><td>'+e.d+'</td><td>'+e.w+'</td><td>'+e.t+'</td><td>'+(e.f?bg('FLAG','var(--neg)'):bg('OK','var(--pos)'))+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Deleted Transactions Recovery</div>'+
'<div class="ci" style="background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent);margin-bottom:8px"><div class="sub" style="line-height:1.5;color:var(--t2)">In Monarch, deleted transactions vanish. NestWorth logs every deletion and lets you restore.</div></div>'+
'<table class="data-table"><thead><tr><th>Transaction</th><th>Amount</th><th>Deleted By</th><th>Date</th><th>Category</th><th></th></tr></thead><tbody>'+
[{n:'Target',a:'$84.50',w:'Caroline',t:'Mar 10',c:'Shopping'},{n:'Uber Eats',a:'$32.00',w:'Caroline',t:'Feb 28',c:'Dining'},{n:'Cash Withdrawal',a:'$200',w:'Von',t:'Feb 15',c:'Cash'},{n:'Amazon Return',a:'$45.99',w:'Von',t:'Feb 8',c:'Shopping'},{n:'Venmo Transfer',a:'$150',w:'Caroline',t:'Jan 22',c:'Transfer'}].map(function(d){return '<tr><td style="font-weight:700;color:var(--neg)">'+d.n+'</td><td class="amount">'+d.a+'</td><td>'+d.w+'</td><td>'+d.t+'</td><td>'+bg(d.c,'var(--info)')+'</td><td><button class="btn-pill" style="font-size:10px;background:var(--posBg);color:var(--pos)">Restore</button></td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Audit Activity Trend</div><div class="chart-subtitle">Events logged per month</div>'+
svgBarChart(auditByMonth.map(function(d){return {label:d.m,value:d.v,color:'var(--acc)'}}),500,160)+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Privacy Settings Matrix</div>'+
'<div class="ci" style="font-size:11px;color:var(--t2);line-height:1.5;margin-bottom:10px">Neither partner can disconnect accounts, delete transactions, or hide data. <strong style="color:var(--acc)">What Monarch doesn\'t do.</strong></div>'+
'<table class="data-table"><thead><tr><th>Feature</th><th>Von</th><th>Caroline</th><th>Status</th></tr></thead><tbody>'+
trustMatrix.map(function(r){return '<tr><td style="font-weight:600;font-size:11px">'+r.f+'</td><td style="font-size:11px">'+r.v+'</td><td style="font-size:11px">'+r.c+'</td><td>'+bg(r.s,'var(--pos)')+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Sync Health Summary</div>'+
'<div class="ci" style="margin-bottom:4px;background:var(--posBg)"><div style="font-weight:700;font-size:11px;color:var(--pos)">4 accounts healthy</div></div>'+
'<div class="ci" style="margin-bottom:4px;background:var(--negBg)"><div style="font-weight:700;font-size:11px;color:var(--neg)">1 account stale (47 days)</div></div>'+
'<div style="margin-top:8px">'+svgLineChart([{m:'W1',v:4},{m:'W2',v:5},{m:'W3',v:4},{m:'W4',v:5},{m:'W5',v:3},{m:'W6',v:4}],340,100,'var(--acc)','Syncs/Week')+'</div></div>'+
'<div class="chart-container" style="margin-bottom:20px"><div class="chart-title">Recommendations</div>'+
[{t:'Resolve 2 open flags',d:'Review Caroline\'s flagged transactions',u:true},{t:'Reconnect Cap One Savings',d:'47 days stale — sync may have broken',u:true},{t:'Enable push notifications',d:'Get real-time alerts on partner actions'},{t:'Schedule monthly transparency review',d:'Set a Money Date to review audit trail'}].map(function(r){return '<div class="ci" style="margin-bottom:6px;'+(r.u?'border-color:color-mix(in srgb,var(--neg) 15%,transparent);background:var(--negBg)':'')+'"><div style="font-weight:700;font-size:11px;color:'+(r.u?'var(--neg)':'var(--t1)')+'">'+r.t+'</div><div class="sub" style="font-size:10px">'+r.d+'</div></div>'}).join('')+'</div>'+
'</div></div></div>';
}
return '<div class="fi">'+
'<button onclick="gb()" style="font-size:13px;font-weight:600;color:var(--t2);margin-bottom:10px;min-height:44px;display:inline-flex;align-items:center">&#x2190; Back</button>'+
'<div class="cs"><div class="r" style="margin-bottom:12px;gap:10px"><div style="width:38px;height:38px;border-radius:19px;background:var(--accS);display:flex;align-items:center;justify-content:center;flex-shrink:0">'+ic(icons.shield,18,'var(--acc)',1.5)+'</div><div style="flex:1"><div style="font-weight:800;font-size:14px">Partner Transparency</div><div class="sub">Both see identical data — no hiding</div></div>'+tg(true)+'</div></div>'+
