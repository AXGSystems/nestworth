'<div><span style="font-size:11px;color:var(--t2)">Total Earned</span> <span style="font-size:14px;font-weight:800;color:var(--pos)">$42,880</span></div>'+
'<div><span style="font-size:11px;color:var(--t2)">Total Spent</span> <span style="font-size:14px;font-weight:800;color:var(--neg)">$27,840</span></div>'+
'<div><span style="font-size:11px;color:var(--t2)">Kept</span> <span style="font-size:14px;font-weight:800;color:var(--acc)">$15,040</span></div>'+
