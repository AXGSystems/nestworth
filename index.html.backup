[{n:'Electric Bill',a:'$145.00',d:'Apr 14',m:true},{n:'Whole Foods',a:'$67.43',d:'Today',m:true},{n:'Gas Station',a:'$48.20',d:'Yesterday',m:true},{n:'Target',a:'$84.50',d:'Apr 10',m:false}].map(function(r){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep);gap:6px">'+ic(icons.receipt,14,'var(--acc)',1.5)+'<div style="flex:1"><div style="font-weight:600;font-size:11px">'+r.n+'</div><div class="sub">'+r.a+' &middot; '+r.d+'</div></div>'+(r.m?bg('Matched','var(--pos)'):bg('Unmatched','var(--warn)'))+'</div>'}).join('')+'</div>'+
