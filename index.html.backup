[{n:'Charitable',a:'$450'},{n:'Medical',a:'$320'},{n:'Home Office',a:'$180'},{n:'Education',a:'$150'},{n:'Tax Prep',a:'$140'}].map(function(t){return '<div class="r" style="padding:3px 0;font-size:11px"><span style="flex:1">'+t.n+'</span><span style="font-weight:700">'+t.a+'</span></div>'}).join('')+
'</div>'+

renderAd('partner')+

'</div>'+/* end dash-side */
'</div>'+/* end dash-row */

/* Full-width Cash Flow Chart */
