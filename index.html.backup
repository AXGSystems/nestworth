'<div class="ci" style="flex:1;text-align:center"><div class="sub" style="font-size:9px">Total Target</div><div style="font-size:18px;font-weight:800">$'+totalGoal.toLocaleString()+'</div></div>'+
'<div class="ci" style="flex:1;text-align:center"><div class="sub" style="font-size:9px">Progress</div><div style="font-size:18px;font-weight:800;color:var(--acc)">'+Math.round((totalSaved/totalGoal)*100)+'%</div></div>'+
