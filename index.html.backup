accounts.map(function(a){return '<tr><td style="font-weight:700">'+a.n+'</td><td>'+bg(a.t,'var(--info)')+'</td><td>'+a.w+'</td><td><div class="dot" style="width:6px;height:6px;display:inline-block;background:'+(a.s==='ok'?'var(--pos)':a.s==='warn'?'var(--warn)':'var(--neg)')+'"></div> '+a.l+' ago</td><td class="amount" style="color:'+(a.v<0?'var(--neg)':'var(--pos)')+'">$'+a.v.toLocaleString()+'</td></tr>'}).join('')+
