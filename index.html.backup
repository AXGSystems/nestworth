/* ========== BUDGET PAGE ========== */
function rBudget(){
var cats=[{n:'Housing',a:2400,s:1500,f:true},{n:'Groceries',a:800,s:480},{n:'Dining Out',a:300,s:280,w:true},{n:'Shopping',a:200,s:235,o:true},{n:'Entertainment',a:150,s:85},{n:'Transport',a:200,s:120},{n:'Subscriptions',a:100,s:62},{n:'Health',a:150,s:45},{n:'Personal',a:200,s:90},{n:'Misc',a:100,s:23}];
var tA=cats.reduce(function(a,c){return a+c.a},0),tS=cats.reduce(function(a,c){return a+c.s},0);

if(isDesktop()){
/* ===== DESKTOP BUDGET ===== */
var budgetPct=Math.round((tS/tA)*100);
var catBarData=cats.filter(function(c){return !c.f}).map(function(c){return {label:c.n,value:c.s,max:c.a,color:c.o?'var(--neg)':c.s/c.a>0.8?'var(--warn)':'var(--pos)'}});
return '<div class="fi">'+

/* Hero: Budget Summary + comparison bar chart */
'<div class="hero dash-full" style="padding:24px 28px 20px">'+
'<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px"><div>'+
'<div style="font-size:13px;opacity:0.85">April Budget &middot; Halfway Through the Month</div>'+
'<div style="font-size:48px;font-weight:800;letter-spacing:-3px;margin-top:2px">$'+tA.toLocaleString()+'</div>'+
'<div style="margin-top:6px;display:flex;gap:20px">'+
'<div><span style="opacity:0.7;font-size:12px">Spent So Far</span> <span style="font-size:18px;font-weight:800">$'+tS.toLocaleString()+'</span></div>'+
'<div><span style="opacity:0.7;font-size:12px">Still Available</span> <span style="font-size:18px;font-weight:800;color:rgba(255,255,255,0.9)">$'+(tA-tS).toLocaleString()+'</span></div>'+
'<div><span style="opacity:0.7;font-size:12px">Used</span> <span style="font-size:18px;font-weight:800">'+budgetPct+'%</span></div>'+
'</div></div>'+
'<div style="text-align:right"><div style="font-size:12px;opacity:0.7">How You Compare</div>'+
'<div style="display:flex;gap:12px;margin-top:6px">'+
monthlyBudgetHistory.map(function(mb){var pct=Math.round((mb.spent/mb.budget)*100);return '<div style="text-align:center"><div style="height:60px;width:32px;background:rgba(255,255,255,0.1);border-radius:6px;position:relative;display:flex;align-items:flex-end;overflow:hidden"><div style="width:100%;height:'+pct+'%;background:rgba(255,255,255,'+(pct>90?0.9:0.5)+');border-radius:6px;transition:height 0.4s"></div></div><div style="font-size:10px;margin-top:3px;opacity:0.7">'+mb.m+'</div><div style="font-size:9px;font-weight:700">'+pct+'%</div></div>'}).join('')+
'</div></div></div>'+
'<div style="margin-top:4px">'+br(budgetPct,'rgba(255,255,255,0.6)',8)+'</div>'+
'<div style="font-size:12px;margin-top:6px;opacity:0.85">$'+(tA-tS).toLocaleString()+' remaining &middot; 12 days left &middot; Safe to spend $140/day</div>'+
'</div>'+

/* Two column layout */
'<div class="dash-row">'+

/* LEFT: Category breakdown with horizontal bars */
'<div class="dash-main">'+
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">How You\'re Tracking by Category</span><span class="view-all" onclick="gp(\'spending\')">Details &rarr;</span></div>'+
'<table class="data-table"><thead><tr><th>Category</th><th>Von</th><th>Caroline</th><th style="text-align:right">Spent</th><th style="text-align:right">Budget</th><th style="width:120px">Progress</th><th>Status</th></tr></thead><tbody>'+
cats.map(function(c){var p=Math.round((c.s/c.a)*100);var vAmt=Math.round(c.s*0.45);var cAmt=Math.round(c.s*0.55);
return '<tr style="cursor:pointer" onclick="os(\''+c.n+'\',sCat(\''+c.n+'\','+c.s+','+c.a+','+vAmt+','+cAmt+'))"><td style="font-weight:600">'+c.n+(c.f?' <span style="font-size:9px;color:var(--t3)">Fixed</span>':'')+'</td><td style="font-size:11px;color:var(--acc)">$'+vAmt+'</td><td style="font-size:11px;color:var(--warn)">$'+cAmt+'</td><td class="amount"'+(c.o?' style="color:var(--neg)"':'')+'>$'+c.s+'</td><td class="amount" style="color:var(--t2)">$'+c.a+'</td><td>'+br(p,c.o?'var(--neg)':p>80?'var(--warn)':'var(--pos)',4)+'</td><td>'+(c.o?bg('OVER','var(--neg)'):c.w?bg(p+'%','var(--warn)'):bg(p+'%','var(--pos)'))+'</td></tr>'}).join('')+
'</tbody></table></div>'+

/* Budget Rollover Tracking (Mint feature) */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Budget Rollover</span></div>'+
'<div class="sub" style="margin-bottom:8px">$1,085 in unspent dollars rolling forward &mdash; money you earned back by staying disciplined</div>'+
'<table class="data-table"><thead><tr><th>Category</th><th style="text-align:right">Unspent</th><th style="text-align:right">Rolled From Mar</th><th style="text-align:right">Running Total</th></tr></thead><tbody>'+
[{n:'Groceries',u:320,r:180,t:500},{n:'Entertainment',u:65,r:45,t:110},{n:'Transport',u:80,r:30,t:110},{n:'Health',u:105,r:90,t:195},{n:'Personal',u:110,r:60,t:170}].map(function(ro){
return '<tr><td style="font-weight:600">'+ro.n+'</td><td class="amount" style="color:var(--pos)">+$'+ro.u+'</td><td class="amount" style="color:var(--t2)">$'+ro.r+'</td><td class="amount" style="font-weight:700">$'+ro.t+'</td></tr>'}).join('')+
'</tbody></table></div>'+

/* Full width: Monthly Spending Trends (6 months by category) */
'<div class="chart-container dash-section"><div class="dash-section-header"><span class="shd">Where the Money Goes Each Month</span></div>'+
'<div class="chart-subtitle">Spending peaked in December and has dropped 18% since &mdash; great momentum</div>'+
svgStackedBarChart(monthlySpending,600,200,
  ['g','d','s','e','t'],
  ['var(--pos)','var(--warn)','var(--neg)','var(--acc)','var(--info)'],
  ['Groceries','Dining','Shopping','Entertainment','Transport'])+
'</div>'+

'</div>'+/* end dash-main */

/* RIGHT: Caps, velocity, forecast */
'<div class="dash-side">'+

/* Category Caps */
'<div class="chart-container dash-section"><div class="chart-title">Spending Guardrails</div>'+
[{c:'Dining Out',l:300,sp:280},{c:'Shopping',l:200,sp:235,o:true},{c:'Entertainment',l:150,sp:148,h:true},{c:'Subscriptions',l:100,sp:62}].map(function(c){var p=Math.round((c.sp/c.l)*100);return '<div class="ci '+(c.h?'pu':'')+'" style="margin-bottom:6px;display:flex;align-items:center;gap:8px;'+(p>=90?'background:var(--negBg);border-color:color-mix(in srgb,var(--neg) 12%,transparent)':'')+'"><div style="flex:1"><div class="r" style="justify-content:space-between;margin-bottom:3px"><span style="font-weight:700;font-size:11px">'+c.c+'</span><span style="font-size:10px;font-weight:700;color:'+(p>=90?'var(--neg)':'var(--t2)')+'">$'+c.sp+'/$'+c.l+'</span></div>'+br(p,p>=100?'var(--neg)':p>=90?'var(--warn)':'var(--pos)',3)+(p>=90?'<div style="font-size:9px;font-weight:700;color:var(--neg);margin-top:2px">Both partners alerted</div>':'')+'</div>'+tg(true,p>=90)+'</div>'}).join('')+
'</div>'+

/* Spending Velocity Chart */
'<div class="chart-container dash-section"><div class="chart-title">Spending Velocity</div>'+
'<div class="chart-subtitle">Your pace is picking up &mdash; spending 38% faster than your 4-week average</div>'+
'<div style="text-align:center;margin-bottom:8px"><span style="font-size:28px;font-weight:900;color:var(--neg)">38%</span><div class="sub">faster than normal &mdash; projected $420 overshoot</div></div>'+
svgLineChart([{m:'W1',v:680},{m:'W2',v:720},{m:'W3',v:850},{m:'W4',v:1066}],340,100,'var(--neg)','Weekly Spend',true)+
'<div class="sub" style="margin-top:6px">Projected overshoot: $420 over budget</div>'+
'</div>'+

/* Annual Forecast */
'<div class="chart-container dash-section" style="cursor:pointer" onclick="os(\'Annual Forecast\',sFore())"><div class="chart-title">Annual Forecast</div>'+
'<div style="text-align:center;margin-bottom:8px"><span style="font-size:28px;font-weight:900;color:var(--pos)">$33.1k</span><div class="sub">on track to save $33,120 by December</div></div>'+
svgLineChart([{m:'Jan',v:2760},{m:'Apr',v:10760},{m:'Jul',v:19320},{m:'Oct',v:27880},{m:'Dec',v:33120}],340,100,'var(--pos)','',true)+
'</div>'+

/* April Summary */
'<div class="chart-container dash-section"><div class="chart-title">April at a Glance</div>'+
