billItems.map(function(b){return '<tr style="cursor:pointer" onclick="os(\''+b.n+'\',sBillA(\''+b.n+'\','+b.sv+'))"><td style="font-weight:700">'+b.n+'</td><td class="amount">$'+b.cur+'</td><td class="amount" style="color:var(--pos)">$'+b.neg+'</td><td class="amount" style="color:var(--pos);font-weight:800">-$'+b.sv+'</td><td>'+bg(b.e,b.e==='Easy'?'var(--pos)':'var(--warn)')+'</td><td style="font-size:11px">'+b.p+'</td><td>'+bg(b.st,b.st==='Ready'?'var(--pos)':b.st==='Pending'?'var(--warn)':'var(--info)')+'</td></tr>'}).join('')+
'</tbody></table></div>'+
'<div class="chart-container"><div class="chart-title">Potential Savings by Category</div>'+
svgBarChart([{label:'Phone',value:60,color:'var(--pos)'},{label:'Insurance',value:38,color:'var(--acc)'},{label:'Internet',value:25,color:'var(--warn)'},{label:'Streaming',value:24,color:'var(--info)'}],400,180)+'</div>'+
'</div><div class="dash-side">'+
'<div class="chart-container"><div class="chart-title">Action Status Tracker</div>'+
billItems.map(function(b){return '<div class="ci" style="margin-bottom:6px"><div class="r" style="margin-bottom:4px"><span style="font-weight:700;font-size:12px;flex:1">'+b.n+'</span>'+bg(b.st,b.st==='Ready'?'var(--pos)':b.st==='Pending'?'var(--warn)':'var(--info)')+'</div>'+br(b.st==='Ready'?100:b.st==='Pending'?60:30,b.st==='Ready'?'var(--pos)':'var(--warn)',3)+'<div class="sub" style="margin-top:2px">Save $'+b.sv+'/mo</div></div>'}).join('')+'</div>'+
'<div class="chart-container"><div class="chart-title">Annual Savings Projection</div>'+
'<div style="text-align:center;margin:12px 0"><div style="font-size:36px;font-weight:900;color:var(--pos)">$1,764</div><div class="sub">per year if all actions completed</div></div>'+
'<div class="ci" style="background:var(--posBg);margin-bottom:6px"><div style="font-size:11px;font-weight:700">5-Year Impact</div><div style="font-size:18px;font-weight:800;color:var(--pos)">$8,820</div></div>'+
'<div class="ci" style="background:var(--accS)"><div style="font-size:11px;font-weight:700">Invested at 7%</div><div style="font-size:18px;font-weight:800;color:var(--acc)">$10,200</div></div></div>'+
'<div class="chart-container"><div class="chart-title">Negotiation Timeline</div>'+
[{d:'Apr 15',n:'Internet renegotiation call',s:'Scheduled'},{d:'Apr 20',n:'Mint Mobile research',s:'In Progress'},{d:'Apr 8',n:'Insurance bundle quote',s:'Complete'},{d:'Mar 30',n:'Streaming audit',s:'Complete'}].map(function(t){return '<div class="r" style="padding:6px 0;border-bottom:0.5px solid var(--sep);gap:6px"><span class="sub" style="width:48px;font-size:10px">'+t.d+'</span><span style="font-size:11px;flex:1">'+t.n+'</span>'+bg(t.s,t.s==='Complete'?'var(--pos)':t.s==='Scheduled'?'var(--warn)':'var(--info)')+'</div>'}).join('')+'</div>'+
pendingBadge('bill negotiation concierge')+
'</div></div></div>';
}
return '<div class="fi">'+
